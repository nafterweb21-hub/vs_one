generator client {
  provider   = "prisma-client-js"
  output     = "../src/generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String                    @id @default(cuid())
  name          String?
  email         String                    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  employeeId    String?                   @unique
  isActive      Boolean                   @default(true)
  passwordHash  String?
  role          UserRole                  @default(VIEWER)
  accounts      Account[]
  approvals     ApprovalPerson[]
  approvedCocs  CertificateOfConformity[] @relation("CocApprovedBy")
  checkedCocs   CertificateOfConformity[] @relation("CocCheckedBy")
  sessions      Session[]
  employee      Employee?                 @relation("EmployeeUser", fields: [employeeId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ApprovalLevelProfile {
  id           String           @id @default(cuid())
  module       String
  actionButton String?
  minRange     Decimal?
  maxRange     Decimal?
  status       String           @default("Active")
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  approvers    ApprovalPerson[]
}

model ApprovalPerson {
  id                     String               @id @default(cuid())
  approvalLevelProfileId String
  userId                 String
  status                 String               @default("Active")
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  approvalLevelProfile   ApprovalLevelProfile @relation(fields: [approvalLevelProfileId], references: [id], onDelete: Cascade)
  user                   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([approvalLevelProfileId, userId])
}

model MaterialType {
  id                        String                   @id @default(cuid())
  type                      String                   @unique
  remark                    String?
  status                    String                   @default("Active")
  processParameterWeldingId String?
  processParameterWelding   ProcessParameterWelding? @relation(fields: [processParameterWeldingId], references: [id])
}

model Currency {
  id             String          @id @default(cuid())
  code           String          @unique
  name           String          @unique
  exchangeRate   Decimal
  isDefault      Boolean         @default(false)
  status         String          @default("Active")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  goodsReceives  GoodsReceive[]
  goodsReturns   GoodsReturn[]
  purchaseOrders PurchaseOrder[]
  quotations     Quotation[]
  salesOrders    SalesOrder[]
  invoices       Invoice[]
}

model Employee {
  id                                            String                          @id @default(cuid())
  code                                          String                          @unique
  name                                          String
  nricFin                                       String                          @unique
  designation                                   String?
  email                                         String
  mobileNo                                      String?
  gender                                        String?
  contactNo                                     String?
  employmentType                                String?
  status                                        String                          @default("ACTIVE")
  createdAt                                     DateTime                        @default(now())
  updatedAt                                     DateTime                        @updatedAt
  cocPainters                                   CertificateOfConformity[]       @relation("CocPainter")
  cocWelders                                    CertificateOfConformity[]       @relation("CocWelder")
  goodsReceives                                 GoodsReceive[]
  goodsReturnCreations                          GoodsReturn[]                   @relation("GoodsReturnCreator")
  Ncr_Ncr_cpaResponsibleStaffIdToEmployee       Ncr[]                           @relation("Ncr_cpaResponsibleStaffIdToEmployee")
  Ncr_Ncr_requestorIdToEmployee                 Ncr[]                           @relation("Ncr_requestorIdToEmployee")
  Ncr_Ncr_responsiblePartyIdToEmployee          Ncr[]                           @relation("Ncr_responsiblePartyIdToEmployee")
  Ncr_Ncr_rootCauseResponsibleStaffIdToEmployee Ncr[]                           @relation("Ncr_rootCauseResponsibleStaffIdToEmployee")
  Ncr_Ncr_verifiedConfirmedByIdToEmployee       Ncr[]                           @relation("Ncr_verifiedConfirmedByIdToEmployee")
  machiningConfirmations                        ProcessParameterMachining[]     @relation("MachiningConfirmedBy")
  sprayConfirmations                            ProcessParameterSprayPainting[] @relation("SprayConfirmedBy")
  weldingConfirmations                          ProcessParameterWelding[]       @relation("WeldingConfirmedBy")
  productionTimesheets                          ProductionTimesheet[]           @relation("TimesheetEmployee")
  purchaseOrders                                PurchaseOrder[]
  purchaseRequisitions                          PurchaseRequisition[]
  quotations                                    Quotation[]
  salesOrders                                   SalesOrder[]
  srfOutsourcedBy                               SubconRequestForm[]             @relation("SrfOutsourcedBy")
  user                                          User?                           @relation("EmployeeUser")
  qcWorkOrders                                  WorkOrder[]                     @relation("WorkOrderQc")
  preparedInvoices                              Invoice[]                       @relation("InvoicePreparedBy")
}

model TaxProfile {
  id             String          @id @default(cuid())
  taxType        String          @unique
  taxRate        Float
  status         String          @default("Active")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  goodsReceives  GoodsReceive[]
  goodsReturns   GoodsReturn[]
  purchaseOrders PurchaseOrder[]
  quotations     Quotation[]
  salesOrders    SalesOrder[]
  invoices       Invoice[]
}

model CustomerProfile {
  id             String                    @id @default(cuid())
  customerCode   String                    @unique
  customerName   String                    @unique
  remarks        String?
  status         String                    @default("Active")
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  cocs           CertificateOfConformity[]
  addresses      CustomerAddress[]
  contactPersons CustomerContactPerson[]
  deliveryOrders DeliveryOrder[]
  Ncr            Ncr[]
  quotations     Quotation[]
  salesOrders    SalesOrder[]
  workOrders     WorkOrder[]
  invoices       Invoice[]
}

model CustomerContactPerson {
  id                String          @id @default(cuid())
  customerId        String
  contactPersonName String
  telNo             String?
  mobileNo          String?
  faxNo             String?
  email             String?
  designation       String?
  status            String          @default("Active")
  isDefault         Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  customer          CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  quotations        Quotation[]
  salesOrders       SalesOrder[]
  invoices          Invoice[]
}

model CustomerAddress {
  id              String          @id @default(cuid())
  customerId      String
  address         String
  status          String          @default("Active")
  isDefault       Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  customer        CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  billToOrders    SalesOrder[]    @relation("BillTo")
  deliverToOrders SalesOrder[]    @relation("DeliverTo")
  invoices        Invoice[]
}

model MaterialCategory {
  id          String            @id @default(cuid())
  name        String            @unique
  description String?
  status      String            @default("Active")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  materials   MaterialProfile[]
}

model MaterialProfile {
  id                       String                    @id @default(cuid())
  partNo                   String?                   @unique
  description              String                    @unique
  shape                    String
  size                     String?
  categoryId               String
  remark                   String?
  status                   String                    @default("Active")
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  category                 MaterialCategory          @relation(fields: [categoryId], references: [id])
  purchaseOrderItems       PurchaseOrderItem[]
  purchaseRequisitionItems PurchaseRequisitionItem[]
}

model WeldingTypeProfile {
  id                        String                   @id @default(cuid())
  type                      String                   @unique
  remark                    String?
  status                    String                   @default("Active")
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  processParameterWeldingId String?
  processParameterWelding   ProcessParameterWelding? @relation(fields: [processParameterWeldingId], references: [id])
}

model PaintingMethodProfile {
  id        String                    @id @default(cuid())
  method    String                    @unique
  remark    String?
  status    String                    @default("Active")
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt
  cocs      CertificateOfConformity[]
}

model MainProcess {
  id                 String              @id @default(cuid())
  process            String              @unique
  remark             String?
  status             String              @default("Active")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  Ncr                Ncr[]
  processProfiles    ProcessProfile[]
  purchaseOrderItems PurchaseOrderItem[]
  routingProcesses   RoutingProcess[]
}

model ProcessProfile {
  id                 String              @id @default(cuid())
  mainProcessId      String
  routingProcess     String              @unique
  welding            Boolean             @default(false)
  sprayPainting      Boolean             @default(false)
  machining          Boolean             @default(false)
  costPerMinute      Decimal
  remark             String?
  status             String              @default("Active")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  mainProcess        MainProcess         @relation(fields: [mainProcessId], references: [id])
  purchaseOrderItems PurchaseOrderItem[]
  routingProcesses   RoutingProcess[]
}

model SupplierProfile {
  id                    String                  @id @default(cuid())
  supplierCode          String                  @unique
  supplierName          String                  @unique
  remarks               String?
  status                String                  @default("Active")
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  goodsReceives         GoodsReceive[]
  goodsReturns          GoodsReturn[]
  purchaseOrders        PurchaseOrder[]
  subconReturnTrackings SubconReturnTracking[]
  addresses             SupplierAddress[]
  contactPersons        SupplierContactPerson[]
}

model SupplierContactPerson {
  id                 String              @id @default(cuid())
  supplierId         String
  contactPersonName  String
  telNo              String?
  mobileNo           String?
  faxNo              String?
  email              String?
  designation        String?
  status             String              @default("Active")
  isDefault          Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  purchaseOrders     PurchaseOrder[]
  subconRequestForms SubconRequestForm[]
  supplier           SupplierProfile     @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}

model SupplierAddress {
  id         String          @id @default(cuid())
  supplierId String
  address    String
  status     String          @default("Active")
  isDefault  Boolean         @default(false)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  supplier   SupplierProfile @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}

model FinishedGoodProfile {
  id              String           @id @default(cuid())
  partNo          String?          @unique
  description     String           @unique
  remark          String?
  status          String           @default("Active")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  quotationItems  QuotationItem[]
  salesOrderItems SalesOrderItem[]
  invoiceItems    InvoiceItem[]
}

model UomProfile {
  id                       String                    @id @default(cuid())
  uomName                  String                    @unique
  remarks                  String?
  status                   String                    @default("Active")
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  cocUoms                  CertificateOfConformity[]
  deliveryOrderItems       DeliveryOrderItem[]
  poItemsInternalUom       PurchaseOrderItem[]       @relation("PoItemInternalUom")
  poItemsPoUom             PurchaseOrderItem[]       @relation("PoItemPoUom")
  purchaseRequisitionItems PurchaseRequisitionItem[]
  quotationItems           QuotationItem[]
  salesOrderItems          SalesOrderItem[]
  workOrders               WorkOrder[]
  invoiceItems             InvoiceItem[]
}

model ElcometerProfile {
  id              String                          @id @default(cuid())
  serialNo        String                          @unique
  remark          String?
  status          String                          @default("Active")
  createdAt       DateTime                        @default(now())
  updatedAt       DateTime                        @updatedAt
  sprayParameters ProcessParameterSprayPainting[]
}

model MachineProfile {
  id                  String                      @id @default(cuid())
  machineCode         String                      @unique
  machineNo           String
  brand               String
  model               String
  current             String?
  serialNo            String?
  machineType         String?
  operationType       String?
  remark              String?
  uploadUrl           String?
  machineCategory     String
  status              String                      @default("Active")
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  cocs                CertificateOfConformity[]
  machiningParameters ProcessParameterMachining[]
  weldingParameters   ProcessParameterWelding[]
}

model PaymentTermProfile {
  id          String       @id @default(cuid())
  name        String       @unique
  days        Int
  remark      String?
  status      String       @default("Active")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  quotations  Quotation[]
  salesOrders SalesOrder[]
  invoices    Invoice[]
}

model SalesOrder {
  id                 String                 @id @default(cuid())
  orderNo            String                 @unique
  revision           Int                    @default(0)
  date               DateTime
  salespersonId      String
  customerId         String
  customerPoRef      String?
  projectCode        String?
  paymentTermId      String
  otherPaymentDetail String?
  refContract        String?
  currencyId         String
  exchangeRate       Decimal
  amountBeforeTax    Decimal
  taxTypeId          String?
  taxRate            Float?
  taxAmount          Decimal?
  amountAfterTax     Decimal
  contactPersonId    String?
  fax                String?
  tel                String?
  email              String?
  deliverToId        String?
  billToId           String?
  remark             String?
  status             String                 @default("Draft")
  uploadUrl          String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  deliveryOrders     DeliveryOrder[]
  quotation          Quotation?
  billTo             CustomerAddress?       @relation("BillTo", fields: [billToId], references: [id])
  contactPerson      CustomerContactPerson? @relation(fields: [contactPersonId], references: [id])
  currency           Currency               @relation(fields: [currencyId], references: [id])
  customer           CustomerProfile        @relation(fields: [customerId], references: [id])
  deliverTo          CustomerAddress?       @relation("DeliverTo", fields: [deliverToId], references: [id])
  paymentTerm        PaymentTermProfile     @relation(fields: [paymentTermId], references: [id])
  salesperson        Employee               @relation(fields: [salespersonId], references: [id])
  taxType            TaxProfile?            @relation(fields: [taxTypeId], references: [id])
  items              SalesOrderItem[]
}

model SalesOrderItem {
  id                    String                @id @default(cuid())
  salesOrderId          String
  partId                String
  quantity              Int
  unitPrice             Decimal               @default(0)
  uomId                 String
  internalQuotationNo   String
  vendorMaterialNo      String?
  materialSpecification String?
  estimateNo            String?
  remark                String?
  uploadUrl             String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  part                  FinishedGoodProfile   @relation(fields: [partId], references: [id])
  salesOrder            SalesOrder            @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  uom                   UomProfile            @relation(fields: [uomId], references: [id])
  batches               SalesOrderItemBatch[]
}

model SalesOrderItemBatch {
  id               String         @id @default(cuid())
  salesOrderItemId String
  quantity         Int
  deliveryDate     DateTime
  workOrderNo      String?
  remark           String?
  noRoutingProcess Boolean        @default(false)
  uploadUrl        String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  salesOrderItem   SalesOrderItem @relation(fields: [salesOrderItemId], references: [id], onDelete: Cascade)
}

model JointProfile {
  id                       String                    @id @default(cuid())
  joint                    String                    @unique
  remark                   String?
  status                   String                    @default("Active")
  createdBy                String?
  updatedBy                String?
  isDeleted                Boolean                   @default(false)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  processParameterWeldings ProcessParameterWelding[]
}

model FailureModeProfile {
  id             String           @id @default(cuid())
  failureMode    String           @unique
  remark         String?
  status         String           @default("Active")
  createdBy      String?
  updatedBy      String?
  isDeleted      Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  NcrFailureMode NcrFailureMode[]
}

model WorkOrder {
  workOrderNo          String                    @id
  date                 DateTime
  customerId           String
  internalQuotationNo  String?
  customerPoRef        String?
  projectCode          String?
  deliveryDate         DateTime?
  jobDescription       String?
  quantity             Decimal?
  uom                  String?
  amount               Decimal?
  remark               String?
  qcAcceptance         String?
  qcById               String?
  qcDate               DateTime?
  labelExpiryDate      DateTime?
  labelQty             Decimal?
  labelUomId           String?
  uploadUrl            String?
  status               String                    @default("Draft")
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  cocs                 CertificateOfConformity[]
  deliveryOrderItems   DeliveryOrderItem[]
  Ncr                  Ncr[]
  purchaseOrders       PurchaseOrder[]
  purchaseRequisitions PurchaseRequisition[]
  customer             CustomerProfile           @relation(fields: [customerId], references: [id])
  labelUom             UomProfile?               @relation(fields: [labelUomId], references: [id])
  qcBy                 Employee?                 @relation("WorkOrderQc", fields: [qcById], references: [id])
  inProcesses          WorkOrderInProcess[]
  invoiceItems         InvoiceItem[]
}

model WorkOrderInProcess {
  id                   String               @id @default(cuid())
  workOrderNo          String
  sn                   Int?
  description          String
  conditionalSnId      String?
  allFlag              Boolean              @default(false)
  targetCompletionDate DateTime
  remark               String?
  status               String               @default("New")
  uploadUrl            String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  Ncr                  Ncr[]
  routingProcesses     RoutingProcess[]
  conditionalSn        WorkOrderInProcess?  @relation("ConditionalSn", fields: [conditionalSnId], references: [id])
  dependentProcesses   WorkOrderInProcess[] @relation("ConditionalSn")
  workOrder            WorkOrder            @relation(fields: [workOrderNo], references: [workOrderNo], onDelete: Cascade)

  @@unique([workOrderNo, description])
}

model RoutingProcess {
  id                   String                @id @default(cuid())
  inProcessId          String
  sn                   String
  mainProcessId        String?
  routingProcessId     String?
  targetCompletionDate DateTime
  fullyReceived        Boolean               @default(false)
  remark               String?
  status               String                @default("New")
  uploadUrl            String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  Ncr                  Ncr[]
  productionTimesheets ProductionTimesheet[]
  purchaseOrderItems   PurchaseOrderItem[]
  inProcess            WorkOrderInProcess    @relation(fields: [inProcessId], references: [id], onDelete: Cascade)
  mainProcess          MainProcess?          @relation(fields: [mainProcessId], references: [id])
  routingProcess       ProcessProfile?       @relation(fields: [routingProcessId], references: [id])

  @@unique([inProcessId, sn])
}

model ProductionTimesheet {
  id                 String                         @id @default(cuid())
  routingProcessId   String
  employeeId         String
  timeIn             DateTime?
  timeOut            DateTime?
  totalMinutes       Decimal?
  completed          Boolean                        @default(false)
  completedQty       Decimal?
  machineCodes       String?
  createdAt          DateTime                       @default(now())
  updatedAt          DateTime                       @updatedAt
  qcRemark           String?
  qcStatus           String                         @default("Pending")
  machiningParameter ProcessParameterMachining?
  sprayParameter     ProcessParameterSprayPainting?
  weldingParameter   ProcessParameterWelding?
  employee           Employee                       @relation("TimesheetEmployee", fields: [employeeId], references: [id])
  routingProcess     RoutingProcess                 @relation(fields: [routingProcessId], references: [id], onDelete: Cascade)
}

model ProcessParameterWelding {
  id               String               @id @default(cuid())
  timesheetId      String               @unique
  weldingMachineId String?
  typeOfJointId    String?
  electrodeType    String?
  weldingPosition  String?
  weldingJoint     Decimal?
  weldingSizeMm    Decimal?
  voltageVolts     Decimal?
  currentAmp       Decimal?
  coolingTimeMins  Decimal?
  preHeatingC      Decimal?
  postHeatingC     Decimal?
  heatTreatmentHrc Decimal?
  remark           String?
  status           String?
  confirmedById    String?
  confirmedDate    DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  materialTypes    MaterialType[]
  confirmedBy      Employee?            @relation("WeldingConfirmedBy", fields: [confirmedById], references: [id])
  timesheet        ProductionTimesheet  @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  typeOfJoint      JointProfile?        @relation(fields: [typeOfJointId], references: [id])
  weldingMachine   MachineProfile?      @relation(fields: [weldingMachineId], references: [id])
  weldingTypes     WeldingTypeProfile[]
}

model ProcessParameterSprayPainting {
  id                        String              @id @default(cuid())
  timesheetId               String              @unique
  paintTankPressurePsi      Decimal
  sprayNozzleSize           Decimal
  typeOfPaint               String
  remark                    String?
  surfaceStartDatetime      DateTime?
  surfaceEndDatetime        DateTime?
  surfaceGeneralWeather     String?
  surfaceEnvTemperature     String?
  surfaceRelativeHumidity   String?
  surfaceAbrasiveType       String?
  surfaceSandpaperGrit      String?
  primerStartDatetime       DateTime?
  primerEndDatetime         DateTime?
  primerGeneralWeather      String?
  primerEnvTemperature      String?
  primerRelativeHumidity    String?
  primerPaintBatchNo        String?
  primerExpiryDate          DateTime?
  primerDftMeasurement      String?
  topcoatStartDatetime      DateTime?
  topcoatEndDatetime        DateTime?
  topcoatGeneralWeather     String?
  topcoatEnvTemperature     String?
  topcoatRelativeHumidity   String?
  topcoatAbrasiveType       String?
  topcoatSandpaperGrit      String?
  topcoatStartDatetime2     DateTime?
  topcoatEndDatetime2       DateTime?
  topcoatGeneralWeather2    String?
  topcoatEnvTemperature2    String?
  topcoatRelativeHumidity2  String?
  topcoatPaintBatchNo       String?
  topcoatExpiryDate         DateTime?
  topcoatDftMeasurement     String?
  topcoatAdhesiveTestResult String?
  additionalRemark          String?
  status                    String?
  elcometerName             String?
  elcometerSerialNoId       String?
  confirmedById             String?
  confirmedDate             DateTime?
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime            @updatedAt
  confirmedBy               Employee?           @relation("SprayConfirmedBy", fields: [confirmedById], references: [id])
  elcometer                 ElcometerProfile?   @relation(fields: [elcometerSerialNoId], references: [id])
  timesheet                 ProductionTimesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
}

model ProcessParameterMachining {
  id                String              @id @default(cuid())
  timesheetId       String              @unique
  machineSerialNoId String
  cncProgramNo      String?
  testRun           String?
  specialTooling    String?
  partRuntimeHr     Decimal?
  partRuntimeMins   Decimal?
  remark            String?
  status            String?
  confirmedById     String?
  confirmedDate     DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  toolLists         MachiningToolList[]
  confirmedBy       Employee?           @relation("MachiningConfirmedBy", fields: [confirmedById], references: [id])
  machine           MachineProfile      @relation(fields: [machineSerialNoId], references: [id])
  timesheet         ProductionTimesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
}

model MachiningToolList {
  id               String                    @id @default(cuid())
  machiningParamId String
  toolValue        Decimal
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  machiningParam   ProcessParameterMachining @relation(fields: [machiningParamId], references: [id], onDelete: Cascade)
}

model CompanyProfile {
  id                    String                 @id @default(cuid())
  companyName           String                 @unique
  address               String
  phoneNo               String
  faxNo                 String
  email                 String?
  website               String?
  rocNo                 String?
  gstRegistrationNo     String
  uploadUrl             String
  logoName              String
  footerName            String
  allowPoForWo          Boolean                @default(false)
  as9100RequirementNote Boolean                @default(false)
  status                String                 @default("Active")
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  goodsReceives         GoodsReceive[]
  goodsReturns          GoodsReturn[]
  purchaseOrders        PurchaseOrder[]
  purchaseRequisitions  PurchaseRequisition[]
  subconReturnTrackings SubconReturnTracking[]
  invoices              Invoice[]
}

model Quotation {
  id                 String                 @id @default(cuid())
  quotationNo        String
  revision           Int                    @default(0)
  date               DateTime
  salespersonId      String
  customerId         String
  contactPersonId    String?
  customerPoRef      String?
  refNo              String?
  title              String
  paymentTermId      String?
  quoteValidityDays  Int                    @default(60)
  leadTime           String?
  incoterms          String?
  currencyId         String
  exchangeRate       Decimal
  subTotal           Decimal
  lumpSumDisc        Decimal                @default(0)
  taxTypeId          String?
  taxRate            Float?
  taxAmount          Decimal?
  totalAmount        Decimal
  termsAndConditions String?
  remark             String?
  uploadUrl          String?
  status             String                 @default("Draft")
  salesOrderId       String?                @unique
  invoiceId          String?                @unique
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  contactPerson      CustomerContactPerson? @relation(fields: [contactPersonId], references: [id])
  currency           Currency               @relation(fields: [currencyId], references: [id])
  customer           CustomerProfile        @relation(fields: [customerId], references: [id])
  paymentTerm        PaymentTermProfile?    @relation(fields: [paymentTermId], references: [id])
  salesOrder         SalesOrder?            @relation(fields: [salesOrderId], references: [id])
  invoice            Invoice?               @relation(fields: [invoiceId], references: [id])
  salesperson        Employee               @relation(fields: [salespersonId], references: [id])
  taxType            TaxProfile?            @relation(fields: [taxTypeId], references: [id])
  items              QuotationItem[]

  @@unique([quotationNo, revision])
}

model QuotationItem {
  id          String               @id @default(cuid())
  quotationId String
  unitPrice   Decimal              @default(0)
  quantity    Int                  @default(1)
  amount      Decimal              @default(0)
  sortOrder   Int                  @default(0)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  partId      String?
  uomId       String?
  part        FinishedGoodProfile? @relation(fields: [partId], references: [id])
  quotation   Quotation            @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  uom         UomProfile?          @relation(fields: [uomId], references: [id])
}

model PurchaseRequisition {
  id             String                    @id @default(cuid())
  prNo           String
  revision       Int                       @default(0)
  date           DateTime
  status         String                    @default("Draft")
  poStatus       String                    @default("N/A")
  remark         String?
  companyId      String
  workOrderNo    String?
  requestedById  String
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  purchaseOrders PurchaseOrder[]
  company        CompanyProfile            @relation(fields: [companyId], references: [id])
  requestedBy    Employee                  @relation(fields: [requestedById], references: [id])
  workOrder      WorkOrder?                @relation(fields: [workOrderNo], references: [workOrderNo])
  items          PurchaseRequisitionItem[]

  @@unique([prNo, revision])
}

model PurchaseRequisitionItem {
  id                     String              @id @default(cuid())
  purchaseRequisitionId  String
  fromMaterialProfile    Boolean             @default(false)
  material               String?
  description            String
  shape                  String?
  size                   String?
  uomId                  String
  quantity               Decimal
  cancelQuantity         Decimal             @default(0)
  prQuantity             Decimal
  deliveryDate           DateTime
  remark                 String?
  poQuantityIssued       Decimal             @default(0)
  balanceRequirePurchase Decimal
  materialProfileId      String?
  sortOrder              Int                 @default(0)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  purchaseOrderItems     PurchaseOrderItem[]
  materialProfile        MaterialProfile?    @relation(fields: [materialProfileId], references: [id])
  purchaseRequisition    PurchaseRequisition @relation(fields: [purchaseRequisitionId], references: [id], onDelete: Cascade)
  uom                    UomProfile          @relation(fields: [uomId], references: [id])
}

model PurchaseOrder {
  id                    String                 @id @default(cuid())
  poNo                  String
  revision              Int                    @default(0)
  date                  DateTime
  companyId             String
  supplierId            String
  workOrderNo           String?
  purchaseRequisitionId String?
  currencyId            String
  exchangeRate          Decimal
  taxTypeId             String
  taxRate               Decimal
  amountBeforeTax       Decimal                @default(0)
  taxAmount             Decimal                @default(0)
  amountAfterTax        Decimal                @default(0)
  millCertificate       Boolean                @default(false)
  certOfConformance     Boolean                @default(false)
  contactPersonId       String?
  telNo                 String                 @default("")
  faxNo                 String                 @default("")
  mobileNo              String                 @default("")
  email                 String                 @default("")
  receiveStatus         String                 @default("NA")
  purchaserId           String
  remark                String                 @default("")
  status                String                 @default("Draft")
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  type                  String                 @default("MATERIAL")
  goodsReceives         GoodsReceive[]
  goodsReturns          GoodsReturn[]
  company               CompanyProfile         @relation(fields: [companyId], references: [id])
  contactPerson         SupplierContactPerson? @relation(fields: [contactPersonId], references: [id])
  currency              Currency               @relation(fields: [currencyId], references: [id])
  purchaseRequisition   PurchaseRequisition?   @relation(fields: [purchaseRequisitionId], references: [id])
  purchaser             Employee               @relation(fields: [purchaserId], references: [id])
  supplier              SupplierProfile        @relation(fields: [supplierId], references: [id])
  taxType               TaxProfile             @relation(fields: [taxTypeId], references: [id])
  workOrder             WorkOrder?             @relation(fields: [workOrderNo], references: [workOrderNo])
  items                 PurchaseOrderItem[]
  subconReturnTrackings SubconReturnTracking[]

  @@unique([poNo, revision])
}

model PurchaseOrderItem {
  id                        String                   @id @default(cuid())
  purchaseOrderId           String
  fromMaterialProfile       Boolean                  @default(false)
  material                  String                   @default("")
  description               String                   @default("")
  supplierMaterialNo        String                   @default("")
  shape                     String                   @default("")
  size                      String                   @default("")
  quantity                  Decimal                  @default(0)
  poUomId                   String
  unitPrice                 Decimal                  @default(0)
  amount                    Decimal                  @default(0)
  conversion                Decimal                  @default(1)
  internalUomId             String?
  internalQuantity          Decimal                  @default(0)
  deliveryDate              DateTime                 @default(now())
  remark                    String                   @default("")
  materialProfileId         String?
  purchaseRequisitionItemId String?
  sortOrder                 Int                      @default(0)
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  masterMainProcessId       String?
  masterRoutingProcessId    String?
  woRoutingProcessId        String?
  hardness                  String?
  thickness                 String?
  goodsReceiveItems         GoodsReceiveItem[]
  internalUom               UomProfile?              @relation("PoItemInternalUom", fields: [internalUomId], references: [id])
  masterMainProcess         MainProcess?             @relation(fields: [masterMainProcessId], references: [id])
  masterRoutingProcess      ProcessProfile?          @relation(fields: [masterRoutingProcessId], references: [id])
  materialProfile           MaterialProfile?         @relation(fields: [materialProfileId], references: [id])
  poUom                     UomProfile               @relation("PoItemPoUom", fields: [poUomId], references: [id])
  purchaseOrder             PurchaseOrder            @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  purchaseRequisitionItem   PurchaseRequisitionItem? @relation(fields: [purchaseRequisitionItemId], references: [id])
  woRoutingProcess          RoutingProcess?          @relation(fields: [woRoutingProcessId], references: [id])
  subconRequestForms        SubconRequestForm[]
}

model Ncr {
  id                                                 String              @id @default(cuid())
  ncrNo                                              String              @unique
  ncrDate                                            DateTime
  customerId                                         String
  workOrderNo                                        String
  inProcessId                                        String?
  mainProcessId                                      String?
  routingProcessId                                   String?
  requestorId                                        String
  responsiblePartyId                                 String?
  descriptionOfNonConformance                        String
  ncrQuantity                                        Int
  reworkQuantity                                     Int                 @default(0)
  useAsIsQuantity                                    Int                 @default(0)
  scrapQuantity                                      Int                 @default(0)
  otherDecisions                                     String?
  otherQuantity                                      Int                 @default(0)
  customerAcceptanceForUseAsIs                       Boolean?
  department                                         String?
  correctiveAction                                   Boolean?
  reasonToJustify                                    String?
  rootCause                                          String?
  rootCauseResponsibleStaffId                        String?
  rootCauseDate                                      DateTime?
  correctivePreventiveAction                         String?
  cpaResponsibleStaffId                              String?
  cpaDate                                            DateTime?
  followUpVerification                               String?
  actionTaken                                        String?
  verifiedConfirmedById                              String?
  verifiedConfirmedDate                              DateTime?
  status                                             String              @default("Draft")
  createdAt                                          DateTime            @default(now())
  updatedAt                                          DateTime            @updatedAt
  Employee_Ncr_cpaResponsibleStaffIdToEmployee       Employee?           @relation("Ncr_cpaResponsibleStaffIdToEmployee", fields: [cpaResponsibleStaffId], references: [id])
  CustomerProfile                                    CustomerProfile     @relation(fields: [customerId], references: [id])
  WorkOrderInProcess                                 WorkOrderInProcess? @relation(fields: [inProcessId], references: [id])
  MainProcess                                        MainProcess?        @relation(fields: [mainProcessId], references: [id])
  Employee_Ncr_requestorIdToEmployee                 Employee            @relation("Ncr_requestorIdToEmployee", fields: [requestorId], references: [id])
  Employee_Ncr_responsiblePartyIdToEmployee          Employee?           @relation("Ncr_responsiblePartyIdToEmployee", fields: [responsiblePartyId], references: [id])
  Employee_Ncr_rootCauseResponsibleStaffIdToEmployee Employee?           @relation("Ncr_rootCauseResponsibleStaffIdToEmployee", fields: [rootCauseResponsibleStaffId], references: [id])
  RoutingProcess                                     RoutingProcess?     @relation(fields: [routingProcessId], references: [id])
  Employee_Ncr_verifiedConfirmedByIdToEmployee       Employee?           @relation("Ncr_verifiedConfirmedByIdToEmployee", fields: [verifiedConfirmedById], references: [id])
  WorkOrder                                          WorkOrder           @relation(fields: [workOrderNo], references: [workOrderNo])
  NcrFailureMode                                     NcrFailureMode[]
}

model NcrFailureMode {
  id                 String             @id @default(cuid())
  ncrId              String
  failureModeId      String
  FailureModeProfile FailureModeProfile @relation(fields: [failureModeId], references: [id], onDelete: Cascade)
  Ncr                Ncr                @relation(fields: [ncrId], references: [id], onDelete: Cascade)

  @@unique([ncrId, failureModeId])
}

model DepartmentProfile {
  id        String   @id @default(cuid())
  name      String   @unique
  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GoodsReceive {
  id              String             @id @default(cuid())
  grNo            String             @unique
  date            DateTime
  companyId       String
  supplierId      String
  purchaseOrderId String
  currencyId      String
  exchangeRate    Decimal
  taxTypeId       String
  taxRate         Decimal
  doNo            String?
  doDate          DateTime?
  invoiceNo       String?
  invoiceDate     DateTime?
  remark          String?
  creatorId       String
  status          String             @default("Draft")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  company         CompanyProfile     @relation(fields: [companyId], references: [id])
  creator         Employee           @relation(fields: [creatorId], references: [id])
  currency        Currency           @relation(fields: [currencyId], references: [id])
  purchaseOrder   PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id])
  supplier        SupplierProfile    @relation(fields: [supplierId], references: [id])
  taxType         TaxProfile         @relation(fields: [taxTypeId], references: [id])
  items           GoodsReceiveItem[]
  goodsReturns    GoodsReturn[]
}

model GoodsReceiveItem {
  id                  String            @id @default(cuid())
  goodsReceiveId      String
  purchaseOrderItemId String
  receiveQty          Decimal
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  goodsReceive        GoodsReceive      @relation(fields: [goodsReceiveId], references: [id], onDelete: Cascade)
  purchaseOrderItem   PurchaseOrderItem @relation(fields: [purchaseOrderItemId], references: [id])
  goodsReturnItems    GoodsReturnItem[]
}

model GoodsReturn {
  id              String            @id @default(cuid())
  rtnNo           String            @unique
  rtnDate         DateTime
  companyId       String
  supplierId      String
  purchaseOrderId String
  goodsReceiveId  String
  currencyId      String
  exchangeRate    Decimal
  taxTypeId       String
  taxRate         Decimal
  remark          String?
  status          String            @default("Draft")
  creatorId       String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  company         CompanyProfile    @relation(fields: [companyId], references: [id])
  creator         Employee          @relation("GoodsReturnCreator", fields: [creatorId], references: [id])
  currency        Currency          @relation(fields: [currencyId], references: [id])
  goodsReceive    GoodsReceive      @relation(fields: [goodsReceiveId], references: [id])
  purchaseOrder   PurchaseOrder     @relation(fields: [purchaseOrderId], references: [id])
  supplier        SupplierProfile   @relation(fields: [supplierId], references: [id])
  taxType         TaxProfile        @relation(fields: [taxTypeId], references: [id])
  items           GoodsReturnItem[]
}

model GoodsReturnItem {
  id                 String           @id @default(cuid())
  goodsReturnId      String
  goodsReceiveItemId String
  returnQty          Decimal
  amount             Decimal
  internalQty        Decimal
  remark             String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  goodsReceiveItem   GoodsReceiveItem @relation(fields: [goodsReceiveItemId], references: [id])
  goodsReturn        GoodsReturn      @relation(fields: [goodsReturnId], references: [id], onDelete: Cascade)
}

model SubconRequestForm {
  id                    String                 @id @default(cuid())
  srfNo                 String                 @unique
  srfDate               DateTime
  purchaseOrderItemId   String
  outsourcedById        String
  dateRequired          DateTime
  receivedById          String?
  quantity              Decimal
  remark                String?
  status                String                 @default("Draft")
  receiveStatus         String                 @default("N/A")
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  outsourcedBy          Employee               @relation("SrfOutsourcedBy", fields: [outsourcedById], references: [id])
  purchaseOrderItem     PurchaseOrderItem      @relation(fields: [purchaseOrderItemId], references: [id])
  receivedBy            SupplierContactPerson? @relation(fields: [receivedById], references: [id])
  subconReturnTrackings SubconReturnTracking[]
}

model SubconReturnTracking {
  id                  String            @id @default(cuid())
  srtNo               String            @unique
  srtDate             DateTime
  companyId           String
  supplierId          String
  purchaseOrderId     String
  subconRequestFormId String
  returnedQty         Decimal
  remark              String?
  status              String            @default("Draft")
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  company             CompanyProfile    @relation(fields: [companyId], references: [id])
  purchaseOrder       PurchaseOrder     @relation(fields: [purchaseOrderId], references: [id])
  subconRequestForm   SubconRequestForm @relation(fields: [subconRequestFormId], references: [id])
  supplier            SupplierProfile   @relation(fields: [supplierId], references: [id])
}

model DeliveryOrder {
  id           String                    @id @default(cuid())
  doNo         String                    @unique
  date         DateTime
  customerId   String
  salesOrderId String
  cocRequired  Boolean                   @default(false)
  status       String                    @default("Draft")
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  cocs         CertificateOfConformity[]
  customer     CustomerProfile           @relation(fields: [customerId], references: [id])
  salesOrder   SalesOrder                @relation(fields: [salesOrderId], references: [id])
  items        DeliveryOrderItem[]
  invoiceLinks InvoiceDeliveryOrder[]
}

model DeliveryOrderItem {
  id              String        @id @default(cuid())
  deliveryOrderId String
  workOrderNo     String
  quantity        Decimal
  uomId           String?
  deliveryDate    DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  deliveryOrder   DeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)
  uom             UomProfile?   @relation(fields: [uomId], references: [id])
  workOrder       WorkOrder     @relation(fields: [workOrderNo], references: [workOrderNo])
}

model CertificateOfConformity {
  id                          String                 @id @default(cuid())
  cocNo                       String                 @unique
  date                        DateTime
  type                        String
  customerId                  String
  deliveryOrderId             String
  workOrderNo                 String
  drawingNo                   String?
  cocQuantity                 Decimal
  cocUomId                    String
  sanNo                       String?
  welderId                    String?
  weldingProcess              String?
  weldingMachineId            String?
  partName                    String?
  partNumber                  String?
  paintingSanNo               String?
  painterId                   String?
  paintingMethodId            String?
  paintingSpecification       String?
  paintThicknessSpecification String?
  measuredTotalPaintThickness String?
  paintBatchNo                String?
  inspectionEquipment         String?
  checkedById                 String?
  checkedDate                 DateTime?
  approvedById                String?
  approvedDate                DateTime?
  status                      String                 @default("Draft")
  createdAt                   DateTime               @default(now())
  updatedAt                   DateTime               @updatedAt
  approvedBy                  User?                  @relation("CocApprovedBy", fields: [approvedById], references: [id])
  checkedBy                   User?                  @relation("CocCheckedBy", fields: [checkedById], references: [id])
  cocUom                      UomProfile             @relation(fields: [cocUomId], references: [id])
  customer                    CustomerProfile        @relation(fields: [customerId], references: [id])
  deliveryOrder               DeliveryOrder          @relation(fields: [deliveryOrderId], references: [id])
  painter                     Employee?              @relation("CocPainter", fields: [painterId], references: [id])
  paintingMethod              PaintingMethodProfile? @relation(fields: [paintingMethodId], references: [id])
  welder                      Employee?              @relation("CocWelder", fields: [welderId], references: [id])
  weldingMachine              MachineProfile?        @relation(fields: [weldingMachineId], references: [id])
  workOrder                   WorkOrder              @relation(fields: [workOrderNo], references: [workOrderNo])

  @@unique([deliveryOrderId, type, workOrderNo, welderId, painterId, partNumber, weldingMachineId, weldingProcess])
}

model Invoice {
  id              String   @id @default(cuid())
  invoiceNo       String   @unique // Format: INVYYXXXXX-RN
  revision        Int      @default(0)
  invoiceDate     DateTime
  companyId       String
  invoiceType     String // Customer Invoice / Credit Note / Debit Note
  customerId      String
  contactPersonId String
  tel             String?
  fax             String?
  email           String?
  billToId        String?
  paymentTermId   String
  dueDate         DateTime
  currencyId      String
  exchangeRate    Decimal
  amountBeforeTax Decimal
  taxTypeId       String
  taxRate         Decimal
  taxAmount       Decimal
  amountAfterTax  Decimal
  amountPaid      Decimal  @default(0) // System calculated from Receipt records
  balanceDue      Decimal
  bankDetails     String?
  remark          String?
  preparedById    String
  uploadUrl       String?
  status          String   @default("Draft") // Draft, Submitted, Old Version, Void
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company       CompanyProfile        @relation(fields: [companyId], references: [id])
  customer      CustomerProfile       @relation(fields: [customerId], references: [id])
  contactPerson CustomerContactPerson @relation(fields: [contactPersonId], references: [id])
  billTo        CustomerAddress?      @relation(fields: [billToId], references: [id])
  paymentTerm   PaymentTermProfile    @relation(fields: [paymentTermId], references: [id])
  currency      Currency              @relation(fields: [currencyId], references: [id])
  taxType       TaxProfile            @relation(fields: [taxTypeId], references: [id])
  preparedBy    Employee              @relation("InvoicePreparedBy", fields: [preparedById], references: [id])

  items          InvoiceItem[]
  deliveryOrders InvoiceDeliveryOrder[]
  quotation      Quotation?
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  lineNo      Int
  workOrderNo String?
  partId      String? // From Sales Order based on WO No
  description String?
  quantity    Decimal
  uomId       String?
  unitPrice   Decimal
  amount      Decimal
  remark      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoice   Invoice              @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  workOrder WorkOrder?           @relation(fields: [workOrderNo], references: [workOrderNo])
  part      FinishedGoodProfile? @relation(fields: [partId], references: [id])
  uom       UomProfile?          @relation(fields: [uomId], references: [id])
}

model InvoiceDeliveryOrder {
  invoiceId       String
  deliveryOrderId String
  createdAt       DateTime @default(now())

  invoice       Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  deliveryOrder DeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Restrict)

  @@id([invoiceId, deliveryOrderId])
}

enum UserRole {
  ADMIN
  SALES
  PRODUCTION
  PURCHASING
  QC
  PLANNER
  VIEWER
}
