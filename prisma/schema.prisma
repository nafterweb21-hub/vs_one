generator client {
  provider   = "prisma-client-js"
  output     = "../src/generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  User              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model ApprovalLevelProfile {
  id             String           @id
  module         String
  actionButton   String?
  minRange       Decimal?
  maxRange       Decimal?
  status         String           @default("Active")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  ApprovalPerson ApprovalPerson[]
}

model ApprovalPerson {
  id                     String               @id
  approvalLevelProfileId String
  userId                 String
  status                 String               @default("Active")
  createdAt              DateTime             @default(now())
  updatedAt              DateTime
  ApprovalLevelProfile   ApprovalLevelProfile @relation(fields: [approvalLevelProfileId], references: [id], onDelete: Cascade)
  User                   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([approvalLevelProfileId, userId])
}

model CompanyProfile {
  id                    String   @id
  companyName           String   @unique
  address               String
  phoneNo               String
  faxNo                 String
  email                 String?
  website               String?
  rocNo                 String?
  gstRegistrationNo     String
  uploadUrl             String
  logoName              String
  footerName            String
  allowPoForWo          Boolean  @default(false)
  as9100RequirementNote Boolean  @default(false)
  status                String   @default("Active")
  createdAt             DateTime @default(now())
  updatedAt             DateTime

  purchaseRequisitions PurchaseRequisition[]
  purchaseOrders       PurchaseOrder[]
}

model Currency {
  id           String       @id
  code         String       @unique
  name         String       @unique
  exchangeRate Decimal
  isDefault    Boolean      @default(false)
  status       String       @default("Active")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime
  Quotation    Quotation[]
  SalesOrder   SalesOrder[]

  purchaseOrders PurchaseOrder[]
}

model CustomerAddress {
  id                                                 String          @id
  customerId                                         String
  address                                            String
  status                                             String          @default("Active")
  isDefault                                          Boolean         @default(false)
  createdAt                                          DateTime        @default(now())
  updatedAt                                          DateTime
  CustomerProfile                                    CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  SalesOrder_SalesOrder_billToIdToCustomerAddress    SalesOrder[]    @relation("SalesOrder_billToIdToCustomerAddress")
  SalesOrder_SalesOrder_deliverToIdToCustomerAddress SalesOrder[]    @relation("SalesOrder_deliverToIdToCustomerAddress")
}

model CustomerContactPerson {
  id                String          @id
  customerId        String
  contactPersonName String
  telNo             String?
  mobileNo          String?
  faxNo             String?
  email             String?
  designation       String?
  status            String          @default("Active")
  isDefault         Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime
  CustomerProfile   CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  Quotation         Quotation[]
  SalesOrder        SalesOrder[]
}

model CustomerProfile {
  id                    String                  @id
  customerCode          String                  @unique
  customerName          String                  @unique
  remarks               String?
  status                String                  @default("Active")
  createdAt             DateTime                @default(now())
  updatedAt             DateTime
  CustomerAddress       CustomerAddress[]
  CustomerContactPerson CustomerContactPerson[]
  Ncr                   Ncr[]
  Quotation             Quotation[]
  SalesOrder            SalesOrder[]
  WorkOrder             WorkOrder[]

  deliveryOrders DeliveryOrder[]
  cocs           CertificateOfConformity[]
}

model DepartmentProfile {
  id        String   @id @default(cuid())
  name      String   @unique
  remark    String?
  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ElcometerProfile {
  id                            String                          @id
  serialNo                      String                          @unique
  remark                        String?
  status                        String                          @default("Active")
  createdAt                     DateTime                        @default(now())
  updatedAt                     DateTime
  ProcessParameterSprayPainting ProcessParameterSprayPainting[]
}

model Employee {
  id                                            String                          @id
  code                                          String                          @unique
  name                                          String
  nricFin                                       String                          @unique
  designation                                   String?
  email                                         String
  mobileNo                                      String?
  gender                                        String?
  contactNo                                     String?
  employmentType                                String?
  status                                        String                          @default("ACTIVE")
  createdAt                                     DateTime                        @default(now())
  updatedAt                                     DateTime
  Ncr_Ncr_cpaResponsibleStaffIdToEmployee       Ncr[]                           @relation("Ncr_cpaResponsibleStaffIdToEmployee")
  Ncr_Ncr_requestorIdToEmployee                 Ncr[]                           @relation("Ncr_requestorIdToEmployee")
  Ncr_Ncr_responsiblePartyIdToEmployee          Ncr[]                           @relation("Ncr_responsiblePartyIdToEmployee")
  Ncr_Ncr_rootCauseResponsibleStaffIdToEmployee Ncr[]                           @relation("Ncr_rootCauseResponsibleStaffIdToEmployee")
  Ncr_Ncr_verifiedConfirmedByIdToEmployee       Ncr[]                           @relation("Ncr_verifiedConfirmedByIdToEmployee")
  ProcessParameterMachining                     ProcessParameterMachining[]
  ProcessParameterSprayPainting                 ProcessParameterSprayPainting[]
  ProcessParameterWelding                       ProcessParameterWelding[]
  ProductionTimesheet                           ProductionTimesheet[]
  Quotation                                     Quotation[]
  SalesOrder                                    SalesOrder[]
  User                                          User?
  WorkOrder                                     WorkOrder[]

  purchaseRequisitions      PurchaseRequisition[]
  purchaseOrdersAsApproval1 PurchaseOrder[]       @relation("PoApproval1")
  purchaseOrdersAsApproval2 PurchaseOrder[]       @relation("PoApproval2")
  purchaseOrdersAsPurchaser PurchaseOrder[]       @relation("PoPurchaser")

  cocsAsWelder     CertificateOfConformity[] @relation("CocWelder")
  cocsAsPainter    CertificateOfConformity[] @relation("CocPainter")
  cocsAsCheckedBy  CertificateOfConformity[] @relation("CocCheckedBy")
  cocsAsApprovedBy CertificateOfConformity[] @relation("CocApprovedBy")
}

model FailureModeProfile {
  id             String           @id
  failureMode    String           @unique
  remark         String?
  status         String           @default("Active")
  createdBy      String?
  updatedBy      String?
  isDeleted      Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  NcrFailureMode NcrFailureMode[]
}

model FinishedGoodProfile {
  id             String           @id
  partNo         String?          @unique
  description    String           @unique
  remark         String?
  status         String           @default("Active")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  QuotationItem  QuotationItem[]
  SalesOrderItem SalesOrderItem[]
}

model JointProfile {
  id                      String                    @id
  joint                   String                    @unique
  remark                  String?
  status                  String                    @default("Active")
  createdBy               String?
  updatedBy               String?
  isDeleted               Boolean                   @default(false)
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime
  ProcessParameterWelding ProcessParameterWelding[]
}

model MachineProfile {
  id                        String                      @id
  machineCode               String                      @unique
  machineNo                 String
  brand                     String
  model                     String
  current                   String?
  serialNo                  String?
  machineType               String?
  operationType             String?
  remark                    String?
  uploadUrl                 String?
  machineCategory           String
  status                    String                      @default("Active")
  createdAt                 DateTime                    @default(now())
  updatedAt                 DateTime
  ProcessParameterMachining ProcessParameterMachining[]
  ProcessParameterWelding   ProcessParameterWelding[]
  cocs                      CertificateOfConformity[]
}

model MachiningToolList {
  id                        String                    @id
  machiningParamId          String
  toolValue                 Decimal
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime
  ProcessParameterMachining ProcessParameterMachining @relation(fields: [machiningParamId], references: [id], onDelete: Cascade)
}

model MainProcess {
  id             String           @id
  process        String           @unique
  remark         String?
  status         String           @default("Active")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  Ncr            Ncr[]
  ProcessProfile ProcessProfile[]
  RoutingProcess RoutingProcess[]
}

model MaterialCategory {
  id              String            @id
  name            String            @unique
  description     String?
  status          String            @default("Active")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  MaterialProfile MaterialProfile[]
}

model MaterialProfile {
  id               String           @id
  partNo           String?          @unique
  description      String           @unique
  shape            String
  size             String?
  categoryId       String
  remark           String?
  status           String           @default("Active")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime
  MaterialCategory MaterialCategory @relation(fields: [categoryId], references: [id])

  purchaseRequisitionItems PurchaseRequisitionItem[]
  purchaseOrderItems       PurchaseOrderItem[]
}

model MaterialType {
  id                        String                   @id
  type                      String                   @unique
  remark                    String?
  status                    String                   @default("Active")
  processParameterWeldingId String?
  ProcessParameterWelding   ProcessParameterWelding? @relation(fields: [processParameterWeldingId], references: [id])
}

model Ncr {
  id                                                 String              @id
  ncrNo                                              String              @unique
  ncrDate                                            DateTime
  customerId                                         String
  workOrderNo                                        String
  inProcessId                                        String?
  mainProcessId                                      String?
  routingProcessId                                   String?
  requestorId                                        String
  responsiblePartyId                                 String?
  descriptionOfNonConformance                        String
  ncrQuantity                                        Int
  reworkQuantity                                     Int                 @default(0)
  useAsIsQuantity                                    Int                 @default(0)
  scrapQuantity                                      Int                 @default(0)
  otherDecisions                                     String?
  otherQuantity                                      Int                 @default(0)
  customerAcceptanceForUseAsIs                       Boolean?
  department                                         String?
  correctiveAction                                   Boolean?
  reasonToJustify                                    String?
  rootCause                                          String?
  rootCauseResponsibleStaffId                        String?
  rootCauseDate                                      DateTime?
  correctivePreventiveAction                         String?
  cpaResponsibleStaffId                              String?
  cpaDate                                            DateTime?
  followUpVerification                               String?
  actionTaken                                        String?
  verifiedConfirmedById                              String?
  verifiedConfirmedDate                              DateTime?
  status                                             String              @default("Draft")
  createdAt                                          DateTime            @default(now())
  updatedAt                                          DateTime
  Employee_Ncr_cpaResponsibleStaffIdToEmployee       Employee?           @relation("Ncr_cpaResponsibleStaffIdToEmployee", fields: [cpaResponsibleStaffId], references: [id])
  CustomerProfile                                    CustomerProfile     @relation(fields: [customerId], references: [id])
  WorkOrderInProcess                                 WorkOrderInProcess? @relation(fields: [inProcessId], references: [id])
  MainProcess                                        MainProcess?        @relation(fields: [mainProcessId], references: [id])
  Employee_Ncr_requestorIdToEmployee                 Employee            @relation("Ncr_requestorIdToEmployee", fields: [requestorId], references: [id])
  Employee_Ncr_responsiblePartyIdToEmployee          Employee?           @relation("Ncr_responsiblePartyIdToEmployee", fields: [responsiblePartyId], references: [id])
  Employee_Ncr_rootCauseResponsibleStaffIdToEmployee Employee?           @relation("Ncr_rootCauseResponsibleStaffIdToEmployee", fields: [rootCauseResponsibleStaffId], references: [id])
  RoutingProcess                                     RoutingProcess?     @relation(fields: [routingProcessId], references: [id])
  Employee_Ncr_verifiedConfirmedByIdToEmployee       Employee?           @relation("Ncr_verifiedConfirmedByIdToEmployee", fields: [verifiedConfirmedById], references: [id])
  WorkOrder                                          WorkOrder           @relation(fields: [workOrderNo], references: [workOrderNo])
  NcrFailureMode                                     NcrFailureMode[]
}

model NcrFailureMode {
  id                 String             @id
  ncrId              String
  failureModeId      String
  FailureModeProfile FailureModeProfile @relation(fields: [failureModeId], references: [id], onDelete: Cascade)
  Ncr                Ncr                @relation(fields: [ncrId], references: [id], onDelete: Cascade)

  @@unique([ncrId, failureModeId])
}

model PaintingMethodProfile {
  id        String   @id
  method    String   @unique
  remark    String?
  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model PaymentTermProfile {
  id         String       @id
  name       String       @unique
  days       Int
  remark     String?
  status     String       @default("Active")
  createdAt  DateTime     @default(now())
  updatedAt  DateTime
  Quotation  Quotation[]
  SalesOrder SalesOrder[]
}

model ProcessParameterMachining {
  id                  String              @id
  timesheetId         String              @unique
  machineSerialNoId   String
  cncProgramNo        String?
  testRun             String?
  specialTooling      String?
  partRuntimeHr       Decimal?
  partRuntimeMins     Decimal?
  remark              String?
  status              String?
  confirmedById       String?
  confirmedDate       DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime
  MachiningToolList   MachiningToolList[]
  Employee            Employee?           @relation(fields: [confirmedById], references: [id])
  MachineProfile      MachineProfile      @relation(fields: [machineSerialNoId], references: [id])
  ProductionTimesheet ProductionTimesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
}

model ProcessParameterSprayPainting {
  id                        String              @id
  timesheetId               String              @unique
  paintTankPressurePsi      Decimal
  sprayNozzleSize           Decimal
  typeOfPaint               String
  remark                    String?
  surfaceStartDatetime      DateTime?
  surfaceEndDatetime        DateTime?
  surfaceGeneralWeather     String?
  surfaceEnvTemperature     String?
  surfaceRelativeHumidity   String?
  surfaceAbrasiveType       String?
  surfaceSandpaperGrit      String?
  primerStartDatetime       DateTime?
  primerEndDatetime         DateTime?
  primerGeneralWeather      String?
  primerEnvTemperature      String?
  primerRelativeHumidity    String?
  primerPaintBatchNo        String?
  primerExpiryDate          DateTime?
  primerDftMeasurement      String?
  topcoatStartDatetime      DateTime?
  topcoatEndDatetime        DateTime?
  topcoatGeneralWeather     String?
  topcoatEnvTemperature     String?
  topcoatRelativeHumidity   String?
  topcoatAbrasiveType       String?
  topcoatSandpaperGrit      String?
  topcoatStartDatetime2     DateTime?
  topcoatEndDatetime2       DateTime?
  topcoatGeneralWeather2    String?
  topcoatEnvTemperature2    String?
  topcoatRelativeHumidity2  String?
  topcoatPaintBatchNo       String?
  topcoatExpiryDate         DateTime?
  topcoatDftMeasurement     String?
  topcoatAdhesiveTestResult String?
  additionalRemark          String?
  status                    String?
  elcometerName             String?
  elcometerSerialNoId       String?
  confirmedById             String?
  confirmedDate             DateTime?
  createdAt                 DateTime            @default(now())
  updatedAt                 DateTime
  Employee                  Employee?           @relation(fields: [confirmedById], references: [id])
  ElcometerProfile          ElcometerProfile?   @relation(fields: [elcometerSerialNoId], references: [id])
  ProductionTimesheet       ProductionTimesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
}

model ProcessParameterWelding {
  id                  String               @id
  timesheetId         String               @unique
  weldingMachineId    String?
  typeOfJointId       String?
  electrodeType       String?
  weldingPosition     String?
  weldingJoint        Decimal?
  weldingSizeMm       Decimal?
  voltageVolts        Decimal?
  currentAmp          Decimal?
  coolingTimeMins     Decimal?
  preHeatingC         Decimal?
  postHeatingC        Decimal?
  heatTreatmentHrc    Decimal?
  remark              String?
  status              String?
  confirmedById       String?
  confirmedDate       DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime
  MaterialType        MaterialType[]
  Employee            Employee?            @relation(fields: [confirmedById], references: [id])
  ProductionTimesheet ProductionTimesheet  @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  JointProfile        JointProfile?        @relation(fields: [typeOfJointId], references: [id])
  MachineProfile      MachineProfile?      @relation(fields: [weldingMachineId], references: [id])
  WeldingTypeProfile  WeldingTypeProfile[]
}

model ProcessProfile {
  id             String           @id
  mainProcessId  String
  routingProcess String           @unique
  welding        Boolean          @default(false)
  sprayPainting  Boolean          @default(false)
  machining      Boolean          @default(false)
  costPerMinute  Decimal
  remark         String?
  status         String           @default("Active")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  MainProcess    MainProcess      @relation(fields: [mainProcessId], references: [id])
  RoutingProcess RoutingProcess[]
}

model ProductionTimesheet {
  id                            String                         @id
  routingProcessId              String
  employeeId                    String
  timeIn                        DateTime?
  timeOut                       DateTime?
  totalMinutes                  Decimal?
  completed                     Boolean                        @default(false)
  completedQty                  Decimal?
  machineCodes                  String?
  createdAt                     DateTime                       @default(now())
  updatedAt                     DateTime
  ProcessParameterMachining     ProcessParameterMachining?
  ProcessParameterSprayPainting ProcessParameterSprayPainting?
  ProcessParameterWelding       ProcessParameterWelding?
  Employee                      Employee                       @relation(fields: [employeeId], references: [id])
  RoutingProcess                RoutingProcess                 @relation(fields: [routingProcessId], references: [id], onDelete: Cascade)
}

model Quotation {
  id                    String                 @id
  quotationNo           String
  revision              Int                    @default(0)
  date                  DateTime
  salespersonId         String
  customerId            String
  contactPersonId       String?
  customerPoRef         String?
  refNo                 String?
  title                 String
  paymentTermId         String?
  quoteValidityDays     Int                    @default(60)
  leadTime              String?
  incoterms             String?
  currencyId            String
  exchangeRate          Decimal
  subTotal              Decimal
  lumpSumDisc           Decimal                @default(0)
  taxTypeId             String?
  taxRate               Float?
  taxAmount             Decimal?
  totalAmount           Decimal
  termsAndConditions    String?
  remark                String?
  uploadUrl             String?
  status                String                 @default("Draft")
  salesOrderId          String?                @unique
  createdAt             DateTime               @default(now())
  updatedAt             DateTime
  CustomerContactPerson CustomerContactPerson? @relation(fields: [contactPersonId], references: [id])
  Currency              Currency               @relation(fields: [currencyId], references: [id])
  CustomerProfile       CustomerProfile        @relation(fields: [customerId], references: [id])
  PaymentTermProfile    PaymentTermProfile?    @relation(fields: [paymentTermId], references: [id])
  SalesOrder            SalesOrder?            @relation(fields: [salesOrderId], references: [id])
  Employee              Employee               @relation(fields: [salespersonId], references: [id])
  TaxProfile            TaxProfile?            @relation(fields: [taxTypeId], references: [id])
  QuotationItem         QuotationItem[]

  @@unique([quotationNo, revision])
}

model QuotationItem {
  id                  String               @id
  quotationId         String
  partId              String?
  uomId               String?
  unitPrice           Decimal              @default(0)
  quantity            Int                  @default(1)
  amount              Decimal              @default(0)
  sortOrder           Int                  @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime
  FinishedGoodProfile FinishedGoodProfile? @relation(fields: [partId], references: [id])
  Quotation           Quotation            @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  UomProfile          UomProfile?          @relation(fields: [uomId], references: [id])
}

model RoutingProcess {
  id                   String                    @id
  inProcessId          String
  sn                   String
  mainProcessId        String?
  routingProcessId     String?
  targetCompletionDate DateTime
  fullyReceived        Boolean                   @default(false)
  remark               String?
  status               String                    @default("New")
  uploadUrl            String?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime
  Ncr                  Ncr[]
  ProductionTimesheet  ProductionTimesheet[]
  WorkOrderInProcess   WorkOrderInProcess        @relation(fields: [inProcessId], references: [id], onDelete: Cascade)
  MainProcess          MainProcess?              @relation(fields: [mainProcessId], references: [id])
  ProcessProfile       ProcessProfile?           @relation(fields: [routingProcessId], references: [id])
  cocs                 CertificateOfConformity[]

  @@unique([inProcessId, sn])
}

model SalesOrder {
  id                                                      String                 @id
  orderNo                                                 String                 @unique
  revision                                                Int                    @default(0)
  date                                                    DateTime
  salespersonId                                           String
  customerId                                              String
  customerPoRef                                           String?
  projectCode                                             String?
  paymentTermId                                           String
  otherPaymentDetail                                      String?
  refContract                                             String?
  currencyId                                              String
  exchangeRate                                            Decimal
  amountBeforeTax                                         Decimal
  taxTypeId                                               String?
  taxRate                                                 Float?
  taxAmount                                               Decimal?
  amountAfterTax                                          Decimal
  contactPersonId                                         String?
  fax                                                     String?
  tel                                                     String?
  email                                                   String?
  deliverToId                                             String?
  billToId                                                String?
  remark                                                  String?
  status                                                  String                 @default("Draft")
  uploadUrl                                               String?
  createdAt                                               DateTime               @default(now())
  updatedAt                                               DateTime
  Quotation                                               Quotation?
  CustomerAddress_SalesOrder_billToIdToCustomerAddress    CustomerAddress?       @relation("SalesOrder_billToIdToCustomerAddress", fields: [billToId], references: [id])
  CustomerContactPerson                                   CustomerContactPerson? @relation(fields: [contactPersonId], references: [id])
  Currency                                                Currency               @relation(fields: [currencyId], references: [id])
  CustomerProfile                                         CustomerProfile        @relation(fields: [customerId], references: [id])
  CustomerAddress_SalesOrder_deliverToIdToCustomerAddress CustomerAddress?       @relation("SalesOrder_deliverToIdToCustomerAddress", fields: [deliverToId], references: [id])
  PaymentTermProfile                                      PaymentTermProfile     @relation(fields: [paymentTermId], references: [id])
  Employee                                                Employee               @relation(fields: [salespersonId], references: [id])
  TaxProfile                                              TaxProfile?            @relation(fields: [taxTypeId], references: [id])
  SalesOrderItem                                          SalesOrderItem[]
}

model SalesOrderItem {
  id                    String                @id
  salesOrderId          String
  partId                String
  quantity              Int
  unitPrice             Decimal               @default(0)
  uomId                 String
  internalQuotationNo   String
  vendorMaterialNo      String?
  materialSpecification String?
  estimateNo            String?
  remark                String?
  uploadUrl             String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime
  FinishedGoodProfile   FinishedGoodProfile   @relation(fields: [partId], references: [id])
  SalesOrder            SalesOrder            @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  UomProfile            UomProfile            @relation(fields: [uomId], references: [id])
  SalesOrderItemBatch   SalesOrderItemBatch[]
}

model SalesOrderItemBatch {
  id               String         @id
  salesOrderItemId String
  quantity         Int
  deliveryDate     DateTime
  workOrderNo      String?
  remark           String?
  noRoutingProcess Boolean        @default(false)
  uploadUrl        String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime
  SalesOrderItem   SalesOrderItem @relation(fields: [salesOrderItemId], references: [id], onDelete: Cascade)
}

model Session {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SupplierAddress {
  id              String          @id
  supplierId      String
  address         String
  status          String          @default("Active")
  isDefault       Boolean         @default(false)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  SupplierProfile SupplierProfile @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}

model SupplierContactPerson {
  id                String          @id
  supplierId        String
  contactPersonName String
  telNo             String?
  mobileNo          String?
  faxNo             String?
  email             String?
  designation       String?
  status            String          @default("Active")
  isDefault         Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime
  SupplierProfile   SupplierProfile @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  purchaseOrders PurchaseOrder[]
}

model SupplierProfile {
  id                    String                  @id
  supplierCode          String                  @unique
  supplierName          String                  @unique
  remarks               String?
  status                String                  @default("Active")
  createdAt             DateTime                @default(now())
  updatedAt             DateTime
  SupplierAddress       SupplierAddress[]
  SupplierContactPerson SupplierContactPerson[]

  purchaseOrders PurchaseOrder[]
}

model TaxProfile {
  id         String       @id
  taxType    String       @unique
  taxRate    Float
  status     String       @default("Active")
  createdAt  DateTime     @default(now())
  updatedAt  DateTime
  Quotation  Quotation[]
  SalesOrder SalesOrder[]

  purchaseOrders PurchaseOrder[]
}

model UomProfile {
  id             String           @id
  uomName        String           @unique
  remarks        String?
  status         String           @default("Active")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  QuotationItem  QuotationItem[]
  SalesOrderItem SalesOrderItem[]
  WorkOrder      WorkOrder[]

  purchaseRequisitionItems        PurchaseRequisitionItem[]
  purchaseOrderItemsAsPoUom       PurchaseOrderItem[]       @relation("PoUom")
  purchaseOrderItemsAsInternalUom PurchaseOrderItem[]       @relation("InternalUom")
  cocsAsWoUom                     CertificateOfConformity[] @relation("CocWoUom")
  cocsAsDoUom                     CertificateOfConformity[] @relation("CocDoUom")
  cocsAsCocUom                    CertificateOfConformity[] @relation("CocUom")
}

model User {
  id             String           @id
  name           String?
  email          String           @unique
  emailVerified  DateTime?
  image          String?
  passwordHash   String?
  role           UserRole         @default(VIEWER)
  isActive       Boolean          @default(true)
  employeeId     String?          @unique
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  Account        Account[]
  ApprovalPerson ApprovalPerson[]
  Session        Session[]
  Employee       Employee?        @relation(fields: [employeeId], references: [id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model WeldingTypeProfile {
  id                        String                   @id
  type                      String                   @unique
  remark                    String?
  status                    String                   @default("Active")
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime
  processParameterWeldingId String?
  ProcessParameterWelding   ProcessParameterWelding? @relation(fields: [processParameterWeldingId], references: [id])
}

model WorkOrder {
  workOrderNo         String               @id
  date                DateTime
  customerId          String
  internalQuotationNo String?
  customerPoRef       String?
  projectCode         String?
  deliveryDate        DateTime?
  jobDescription      String?
  quantity            Decimal?
  uom                 String?
  amount              Decimal?
  remark              String?
  qcAcceptance        String?
  qcById              String?
  qcDate              DateTime?
  labelExpiryDate     DateTime?
  labelQty            Decimal?
  labelUomId          String?
  uploadUrl           String?
  status              String               @default("Draft")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime
  Ncr                 Ncr[]
  CustomerProfile     CustomerProfile      @relation(fields: [customerId], references: [id])
  UomProfile          UomProfile?          @relation(fields: [labelUomId], references: [id])
  Employee            Employee?            @relation(fields: [qcById], references: [id])
  WorkOrderInProcess  WorkOrderInProcess[]

  purchaseRequisitions PurchaseRequisition[]
  purchaseOrders       PurchaseOrder[]
  cocs                 CertificateOfConformity[]
}

model WorkOrderInProcess {
  id                       String               @id
  workOrderNo              String
  sn                       Int?
  description              String
  conditionalSnId          String?
  allFlag                  Boolean              @default(false)
  targetCompletionDate     DateTime
  remark                   String?
  status                   String               @default("New")
  uploadUrl                String?
  createdAt                DateTime             @default(now())
  updatedAt                DateTime
  Ncr                      Ncr[]
  RoutingProcess           RoutingProcess[]
  WorkOrderInProcess       WorkOrderInProcess?  @relation("WorkOrderInProcessToWorkOrderInProcess", fields: [conditionalSnId], references: [id])
  other_WorkOrderInProcess WorkOrderInProcess[] @relation("WorkOrderInProcessToWorkOrderInProcess")
  WorkOrder                WorkOrder            @relation(fields: [workOrderNo], references: [workOrderNo], onDelete: Cascade)

  @@unique([workOrderNo, description])
}

enum UserRole {
  ADMIN
  SALES
  PRODUCTION
  PURCHASING
  QC
  PLANNER
  VIEWER
}

// ==========================================
// Purchase Requisition Module
// ==========================================
model PurchaseRequisition {
  id       String   @id @default(cuid())
  prNo     String // PRYYXXXXX (e.g. PR1700003) - shared across revisions
  revision Int      @default(0) // Revision count (starts at 0)
  date     DateTime // Entry Date (default today, forward allowed, no backdate)
  status   String   @default("Draft") // Draft / Void / Submitted
  poStatus String   @default("N/A") // N/A / Partially Issued / Fully Issued / Cancelled
  remark   String?

  companyId String
  company   CompanyProfile @relation(fields: [companyId], references: [id])

  workOrderNo String?
  workOrder   WorkOrder? @relation(fields: [workOrderNo], references: [workOrderNo])

  requestedById String
  requestedBy   Employee @relation(fields: [requestedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items          PurchaseRequisitionItem[]
  purchaseOrders PurchaseOrder[]

  @@unique([prNo, revision])
}

model PurchaseRequisitionItem {
  id                    String              @id @default(cuid())
  purchaseRequisitionId String
  purchaseRequisition   PurchaseRequisition @relation(fields: [purchaseRequisitionId], references: [id], onDelete: Cascade)

  fromMaterialProfile Boolean    @default(false)
  material            String? // Input material text or code
  description         String // Description (from profile or user input)
  shape               String?
  size                String?
  uomId               String
  uom                 UomProfile @relation(fields: [uomId], references: [id])

  quantity       Decimal // Decimal (2 decimals)
  cancelQuantity Decimal  @default(0) // Decimal (2 decimals)
  prQuantity     Decimal // System calculated: quantity - cancelQuantity
  deliveryDate   DateTime // Required
  remark         String?

  poQuantityIssued       Decimal @default(0) // System calculated based on issued POs
  balanceRequirePurchase Decimal // System calculated: prQuantity - poQuantityIssued

  materialProfileId String?
  materialProfile   MaterialProfile? @relation(fields: [materialProfileId], references: [id])

  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseOrderItems PurchaseOrderItem[]
}

// ==========================================
// Purchase Order Module
// ==========================================
model PurchaseOrder {
  id       String   @id @default(cuid())
  poNo     String // POYYXXXXX (e.g. PO1700003) - shared across revisions
  revision Int      @default(0)
  date     DateTime

  companyId String
  company   CompanyProfile @relation(fields: [companyId], references: [id])

  supplierId String
  supplier   SupplierProfile @relation(fields: [supplierId], references: [id])

  workOrderNo String?
  workOrder   WorkOrder? @relation(fields: [workOrderNo], references: [workOrderNo])

  purchaseRequisitionId String?
  purchaseRequisition   PurchaseRequisition? @relation(fields: [purchaseRequisitionId], references: [id])

  currencyId   String
  currency     Currency @relation(fields: [currencyId], references: [id])
  exchangeRate Decimal

  taxTypeId String
  taxType   TaxProfile @relation(fields: [taxTypeId], references: [id])
  taxRate   Float

  amountBeforeTax Decimal
  taxAmount       Decimal
  amountAfterTax  Decimal

  millCertificate   Boolean @default(false)
  certOfConformance Boolean @default(false)

  contactPersonId String
  contactPerson   SupplierContactPerson @relation(fields: [contactPersonId], references: [id])
  telNo           String?
  faxNo           String?
  mobileNo        String?
  email           String

  approval1ById String?
  approval1By   Employee? @relation("PoApproval1", fields: [approval1ById], references: [id])
  approval1Date DateTime?

  approval2ById String?
  approval2By   Employee? @relation("PoApproval2", fields: [approval2ById], references: [id])
  approval2Date DateTime?

  receiveStatus String @default("NA")

  purchaserId String
  purchaser   Employee @relation("PoPurchaser", fields: [purchaserId], references: [id])

  remark String?
  status String  @default("Draft")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items PurchaseOrderItem[]

  @@unique([poNo, revision])
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  fromMaterialProfile Boolean @default(false)
  material            String?
  description         String
  supplierMaterialNo  String?
  shape               String?
  size                String?

  quantity Decimal

  poUomId String
  poUom   UomProfile @relation("PoUom", fields: [poUomId], references: [id])

  unitPrice Decimal
  amount    Decimal

  conversion Decimal @default(1)

  internalUomId String?
  internalUom   UomProfile? @relation("InternalUom", fields: [internalUomId], references: [id])

  internalQuantity Decimal

  totalReceived Decimal @default(0)
  totalReturned Decimal @default(0)
  nettReceived  Decimal @default(0)

  deliveryDate DateTime
  remark       String?

  materialProfileId String?
  materialProfile   MaterialProfile? @relation(fields: [materialProfileId], references: [id])

  purchaseRequisitionItemId String?
  purchaseRequisitionItem   PurchaseRequisitionItem? @relation(fields: [purchaseRequisitionItemId], references: [id])

  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// Delivery Order Module (Stub)
// ==========================================
model DeliveryOrder {
  id          String          @id @default(cuid())
  doNo        String          @unique
  date        DateTime
  customerId  String
  customer    CustomerProfile @relation(fields: [customerId], references: [id])
  cocRequired Boolean         @default(false)
  status      String          @default("Draft") // Draft / Submitted

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cocs CertificateOfConformity[]
}

// ==========================================
// Certificate Of Conformity (COC) Module
// ==========================================
model CocSequence {
  id        String @id @default("coc-sequence")
  year      Int
  lastValue Int    @default(0)
}

model CocTypeProfile {
  id        String   @id @default(cuid())
  type      String   @unique
  remark    String?
  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cocs CertificateOfConformity[]
}

model CertificateOfConformity {
  id    String   @id @default(cuid())
  cocNo String   @unique
  date  DateTime
  
  cocTypeId String
  cocType   CocTypeProfile @relation(fields: [cocTypeId], references: [id])

  customerId String
  customer   CustomerProfile @relation(fields: [customerId], references: [id])

  deliveryOrderId String
  deliveryOrder   DeliveryOrder @relation(fields: [deliveryOrderId], references: [id])

  workOrderNo String
  workOrder   WorkOrder @relation(fields: [workOrderNo], references: [workOrderNo])

  routingProcessId String?
  routingProcess   RoutingProcess? @relation(fields: [routingProcessId], references: [id])

  description   String?
  drawingNo     String?
  customerRefNo String?

  woQuantity Decimal?
  doQuantity Decimal?
  woUomId    String?
  woUom      UomProfile? @relation("CocWoUom", fields: [woUomId], references: [id])

  doUomId String?
  doUom   UomProfile? @relation("CocDoUom", fields: [doUomId], references: [id])

  cocQuantity Decimal?
  cocUomId    String?
  cocUom      UomProfile? @relation("CocUom", fields: [cocUomId], references: [id])

  // Welding specifics
  sanNo            String?
  welderId         String?
  welder           Employee?       @relation("CocWelder", fields: [welderId], references: [id])
  weldingProcess   String?
  weldingMachineId String?
  weldingMachine   MachineProfile? @relation(fields: [weldingMachineId], references: [id])

  // Spray Painting specifics
  partName                    String?
  partNumber                  String?
  paintingSanNo               String?
  painterId                   String?
  painter                     Employee? @relation("CocPainter", fields: [painterId], references: [id])
  paintingMethod              String?
  paintingSpecification       String?
  paintThicknessSpecification String?
  measuredTotalPaintThickness String?
  paintBatchNo                String?
  inspectionEquipment         String?

  checkedById String?
  checkedBy   Employee? @relation("CocCheckedBy", fields: [checkedById], references: [id])

  approvedById String?
  approvedBy   Employee? @relation("CocApprovedBy", fields: [approvedById], references: [id])

  status String @default("Draft") // Draft, Require Approval, Approved, Void

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
