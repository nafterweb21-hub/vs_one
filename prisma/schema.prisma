generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ApprovalLevelProfile {
  id           String           @id @default(cuid())
  module       String           // e.g., "Purchase Order - Material", "Purchase Order - Subcon"
  actionButton String?          // e.g., "First Level", "Second Level"
  minRange     Decimal?
  maxRange     Decimal?
  status       String           @default("Active") // "Active" or "Inactive"
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  approvers    ApprovalPerson[]
}

model Company {
  id                    String   @id @default(cuid())
  name                  String   @unique
  address               String   @db.Text
  phoneNo               String
  faxNo                 String
  email                 String?
  website               String?
  rocNo                 String?
  gstRegistrationNo     String
  uploadUrl             String   @db.Text
  logoUrl               String?  @db.Text
  footerUrl             String?  @db.Text
  logoName              String
  footerName            String
  allowCreatePoForWo    Boolean  @default(false)
  as9100RequirementNote Boolean  @default(false)
  status                String   @default("Active")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model PaymentTerm {
  id        String   @id @default(cuid())
  term      String   @unique
  day       Int
  remark    String?  @db.Text
  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// Currency Profile
// ==========================================
model Currency {
  id           String   @id @default(cuid())
  code         String   @unique // Immutable
  name         String   @unique // Immutable
  exchangeRate Decimal
  isDefault    Boolean  @default(false)
  status       String   @default("Active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  salesOrders  SalesOrder[]
}

model TaxProfile {
  id        String   @id @default(cuid())
  taxType   String   @unique
  taxRate   Float
  status    String   @default("Active") // "Active" or "Inactive"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  salesOrders SalesOrder[]
}

model Joint {
  id        String   @id @default(cuid())
  joint     String   @unique
  remark    String?  @db.Text
  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FailureMode {
  id          String   @id @default(cuid())
  failureMode String   @unique
  remark      String?  @db.Text
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Employee {
  id             String   @id @default(cuid())
  code           String   @unique
  name           String
  nricFin        String   @unique
  designation    String?
  email          String
  mobileNo       String?
  gender         String?  // Male / Female
  contactNo      String?
  employmentType String?  // Citizen / PR / Employment Pass / S Pass / Work Permit
  status         String   @default("ACTIVE") // ACTIVE / INACTIVE
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  salesOrders            SalesOrder[]
  workOrdersQC           WorkOrder[] @relation("WOQCBy")
  woRoutingProcesses     WorkOrderRoutingProcess[] @relation("WORoutingEmployee")
  woTimesheets           ProductionTimesheet[] @relation("WOTimesheetEmployee")
  woWeldingConfirmations WeldingParameter[] @relation("WOWeldingConfirm")
  woPaintingConfirm      SprayPaintingParameter[] @relation("WOPaintingConfirm")
  woMachiningConfirm     MachiningParameter[] @relation("WOMachiningConfirm")
  woQcInspections        QcApproval[] @relation("WOQCInspector")
  woNcrReports           NcrReport[] @relation("WONCRReportedBy")
}

model CustomerProfile {
  id             String                  @id @default(cuid())
  customerCode   String                  @unique
  customerName   String                  @unique
  remarks        String?                 @db.Text
  status         String                  @default("Active") // "Active" or "Inactive"
  contactPersons CustomerContactPerson[]
  addresses      CustomerAddress[]
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  salesOrders    SalesOrder[]
}

model CustomerContactPerson {
  id                String          @id @default(cuid())
  customerId        String
  customer          CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  contactPersonName String
  telNo             String?
  mobileNo          String?
  faxNo             String?
  email             String?
  designation       String?
  status            String          @default("Active") // "Active" or "Inactive"
  isDefault         Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  salesOrders       SalesOrder[]
}

model CustomerAddress {
  id         String          @id @default(cuid())
  customerId String
  customer   CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  address    String          @db.Text
  status     String          @default("Active") // "Active" or "Inactive"
  isDefault  Boolean         @default(false)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  deliverToOrders SalesOrder[] @relation("DeliverTo")
  billToOrders    SalesOrder[] @relation("BillTo")
}

model MaterialCategory {
  id          String            @id @default(cuid())
  name        String            @unique
  description String?
  status      String            @default("Active") // "Active" or "Inactive"
  materials   MaterialProfile[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model MaterialProfile {
  id                 String           @id @default(cuid())
  partNo             String?          @unique // Not mandatory, unique
  description        String           @unique // Mandatory, unique
  shape              String           // Mandatory
  size               String?          // Not mandatory
  categoryId         String           // Dropdown from Material Category profile
  category           MaterialCategory @relation(fields: [categoryId], references: [id])
  remark             String?
  status             String           @default("Active") // Default Active
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model WeldingTypeProfile {
  id        String   @id @default(cuid())
  type      String   @unique
  remark    String?  @db.Text
  status    String   @default("Active") // "Active" or "Inactive"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// UOM Profile
// ==========================================
model UomProfile {
  id        String   @id @default(cuid())
  uomName   String   @unique // Immutable after save
  remarks   String?
  status    String   @default("Active") // "Active" or "Inactive"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  salesOrderItems SalesOrderItem[]
}

model MainProcess {
  id              String           @id @default(cuid())
  process         String           @unique
  remark          String?
  status          String           @default("Active") // "Active", "Inactive", or "Void"
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  processProfiles ProcessProfile[]
  woRoutingProcesses WorkOrderRoutingProcess[]
}

model ProcessProfile {
  id              String      @id @default(cuid())
  mainProcessId   String
  mainProcess     MainProcess @relation(fields: [mainProcessId], references: [id])
  routingProcess  String      @unique
  welding         Boolean     @default(false)
  sprayPainting   Boolean     @default(false)
  machining       Boolean     @default(false)
  costPerMinute   Decimal
  remark          String?
  status          String      @default("Active") // "Active", "Inactive", or "Void"
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  woRoutingProcesses WorkOrderRoutingProcess[]
}

model SupplierProfile {
  id             String                  @id @default(cuid())
  supplierCode   String                  @unique
  supplierName   String                  @unique
  remarks        String?                 @db.Text
  status         String                  @default("Active") // "Active" or "Inactive"
  contactPersons SupplierContactPerson[]
  addresses      SupplierAddress[]
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
}

model SupplierContactPerson {
  id                String          @id @default(cuid())
  supplierId        String
  supplier          SupplierProfile @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  contactPersonName String
  telNo             String?
  mobileNo          String?
  faxNo             String?
  email             String?
  designation       String?
  status            String          @default("Active") // "Active" or "Inactive"
  isDefault         Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model SupplierAddress {
  id         String          @id @default(cuid())
  supplierId String
  supplier   SupplierProfile @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  address    String          @db.Text
  status     String          @default("Active") // "Active" or "Inactive"
  isDefault  Boolean         @default(false)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
}

model FinishedGoodProfile {
  id          String   @id @default(cuid())
  partNo      String?  @unique
  description String   @unique @db.Text
  remark      String?  @db.Text
  status      String   @default("Active") // "Active" or "Inactive"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  salesOrderItems SalesOrderItem[]
}

// ==========================================
// Currency Profile
// ==========================================
model Currency {
  id           String   @id @default(cuid())
  code         String   @unique // Immutable
  name         String   @unique // Immutable
  exchangeRate Decimal
  isDefault    Boolean  @default(false)
  status       String   @default("Active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  salesOrders  SalesOrder[]
}

// ==========================================
// Elcometer Profile
// ==========================================
model ElcometerProfile {
  id        String   @id @default(cuid())
  serialNo  String   @unique // Immutable after save
  remark    String?
  status    String   @default("Active") // "Active" or "Inactive"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// Machine Profile
// ==========================================
model MachineProfile {
  id              String   @id @default(cuid())
  machineCode     String   @unique // Immutable after save
  machineNo       String
  brand           String
  model           String
  current         String?
  serialNo        String?  // S/No
  machineType     String?  // CNC / Convention
  operationType   String?  // Milling / Turning
  remark          String?
  uploadUrl       String?  // File Upload path
  machineCategory String   // Welding Machine / Machine
  status          String   @default("Active") // "Active" or "Inactive"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  woTimesheets    ProductionTimesheet[]
}

// ==========================================
// Payment Term Profile
// ==========================================
model PaymentTermProfile {
  id        String   @id @default(cuid())
  name      String   @unique
  days      Int
  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  salesOrders SalesOrder[]
}

// ==========================================
// Sales Order
// ==========================================
model SalesOrder {
  id                String   @id @default(cuid())
  orderNo           String   @unique // Auto Generated
  revision          Int      @default(0) // Increases on confirmation
  date              DateTime // No backdate logic on frontend
  
  salespersonId     String
  salesperson       Employee @relation(fields: [salespersonId], references: [id])
  
  customerId        String
  customer          CustomerProfile @relation(fields: [customerId], references: [id])
  
  customerPoRef     String?
  projectCode       String?
  
  paymentTermId     String
  paymentTerm       PaymentTermProfile @relation(fields: [paymentTermId], references: [id])
  
  otherPaymentDetail String?
  refContract       String?
  
  currencyId        String
  currency          Currency @relation(fields: [currencyId], references: [id])
  exchangeRate      Decimal
  
  amountBeforeTax   Decimal
  
  taxTypeId         String?
  taxType           TaxProfile? @relation(fields: [taxTypeId], references: [id])
  taxRate           Float?
  taxAmount         Decimal?
  amountAfterTax    Decimal
  
  contactPersonId   String?
  contactPerson     CustomerContactPerson? @relation(fields: [contactPersonId], references: [id])
  
  fax               String?
  tel               String?
  email             String?
  
  deliverToId       String?
  deliverTo         CustomerAddress? @relation("DeliverTo", fields: [deliverToId], references: [id])
  
  billToId          String?
  billTo            CustomerAddress? @relation("BillTo", fields: [billToId], references: [id])
  
  remark            String?
  status            String   @default("Draft") // Draft / Confirmed / Closed
  uploadUrl         String?
  
  items             SalesOrderItem[]
  workOrders        WorkOrder[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model SalesOrderItem {
  id               String   @id @default(cuid())
  salesOrderId     String
  salesOrder       SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  
  partId           String
  part             FinishedGoodProfile @relation(fields: [partId], references: [id])
  
  quantity         Int
  
  uomId            String
  uom              UomProfile @relation(fields: [uomId], references: [id])
  
  deliveryDate     DateTime
  workOrderNo      String?
  remark           String?
  noRoutingProcess Boolean  @default(false)
  uploadUrl        String?
  workOrderRef     WorkOrder?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ==========================================
// Work Order Management
// ==========================================
model WorkOrder {
  id                  String   @id @default(cuid())
  workOrderNo         String   @unique // Auto Generate: SO_NO-A-B
  date                DateTime @default(now())
  
  salesOrderId        String
  salesOrder          SalesOrder @relation(fields: [salesOrderId], references: [id])
  salesOrderItemId    String   @unique
  salesOrderItem      SalesOrderItem @relation(fields: [salesOrderItemId], references: [id])
  
  // Fields populated from SO
  customerName        String
  internalQuotationNo String?
  customerPoRef       String?
  projectCode         String?
  deliveryDate        DateTime
  jobDescription      String
  quantity            Int
  uom                 String
  amount              Decimal
  
  remark              String?
  uploadUrl           String?
  
  // QC Fields
  qcAcceptance        String?  // N/A, Rejected, Approved
  qcById              String?
  qcBy                Employee? @relation("WOQCBy", fields: [qcById], references: [id])
  qcDate              DateTime?
  
  // Label Print
  labelExpiryDate     DateTime?
  labelQty            Int?
  labelUom            String?
  
  status              String   @default("Draft")
  
  inProcessSteps      WorkOrderInProcess[]
  qcApprovals         QcApproval[]
  ncrReports          NcrReport[]

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model WorkOrderInProcess {
  id                  String   @id @default(cuid())
  workOrderNo         String
  workOrder           WorkOrder @relation(fields: [workOrderNo], references: [workOrderNo], onDelete: Cascade)
  
  sn                  Int
  description         String
  conditionalSn       Int?
  all                 Boolean  @default(false)
  targetCompletionDate DateTime
  remark              String?
  status              String   @default("New") // New, WIP, Completed
  uploadUrl           String?
  
  routingProcesses    WorkOrderRoutingProcess[]

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  @@unique([workOrderNo, sn])
}

model WorkOrderRoutingProcess {
  id                  String   @id @default(cuid())
  inProcessId         String
  inProcess           WorkOrderInProcess @relation(fields: [inProcessId], references: [id], onDelete: Cascade)
  
  sn                  String   // e.g., "1.1"
  mainProcessId       String
  mainProcess         MainProcess @relation(fields: [mainProcessId], references: [id])
  routingProcessId    String
  routingProcess      ProcessProfile @relation(fields: [routingProcessId], references: [id])
  
  targetCompletionDate DateTime
  fullyReceived       Boolean? // Nullable if not subcon
  employeeId          String?
  employee            Employee? @relation("WORoutingEmployee", fields: [employeeId], references: [id])
  remark              String?
  status              String   @default("New") // New, WIP, Completed
  uploadUrl           String?
  
  timesheets          ProductionTimesheet[]
  weldingParams       WeldingParameter[]
  paintingParams      SprayPaintingParameter[]
  machiningParams     MachiningParameter[]

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model ProductionTimesheet {
  id                  String   @id @default(cuid())
  routingProcessId    String
  routingProcess      WorkOrderRoutingProcess @relation(fields: [routingProcessId], references: [id], onDelete: Cascade)
  
  employeeId          String
  employee            Employee @relation("WOTimesheetEmployee", fields: [employeeId], references: [id])
  
  timeIn              DateTime
  timeOut             DateTime?
  totalMinutes        Int?
  completed           Boolean  @default(false)
  completedQty        Int      @default(0)
  machineCodeId       String?
  machineCode         MachineProfile? @relation(fields: [machineCodeId], references: [id])
  
  routingCost         Decimal?
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model WeldingParameter {
  id                  String   @id @default(cuid())
  routingProcessId    String
  routingProcess      WorkOrderRoutingProcess @relation(fields: [routingProcessId], references: [id], onDelete: Cascade)
  
  materialType        String?
  weldingType         String?
  weldingMachine      String?
  machineNo           String?
  brand               String?
  model               String?
  current             String?
  serialNo            String?
  typeOfJoint         String?
  electrodeType       String?
  weldingPosition     String?
  weldingJoint        String?
  weldingSize         String?
  voltage             String?
  currentAmp          String?
  coolingTime         String?
  preHeating          String?
  postHeating         String?
  heatTreatment       String?
  remark              String?
  status              String   @default("Pending")
  confirmedById       String?
  confirmedBy         Employee? @relation("WOWeldingConfirm", fields: [confirmedById], references: [id])
  confirmedDate       DateTime?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model SprayPaintingParameter {
  id                  String   @id @default(cuid())
  routingProcessId    String
  routingProcess      WorkOrderRoutingProcess @relation(fields: [routingProcessId], references: [id], onDelete: Cascade)
  
  paintTankPressure   String?
  sprayNozzleSize     String?
  typeOfPaint         String?
  weatherCondition    String?
  environmentalTemp   String?
  relativeHumidity    String?
  abrasiveType        String?
  sandpaperGrit       String?
  paintBatchNo        String?
  expiryDate          DateTime?
  dftMeasurementResult String?
  adhesiveTestResult  String?
  additionalRemark    String?
  elcometerName       String?
  elcometerSerialNo   String?
  confirmedById       String?
  confirmedBy         Employee? @relation("WOPaintingConfirm", fields: [confirmedById], references: [id])
  confirmedDate       DateTime?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model MachiningParameter {
  id                  String   @id @default(cuid())
  routingProcessId    String
  routingProcess      WorkOrderRoutingProcess @relation(fields: [routingProcessId], references: [id], onDelete: Cascade)
  
  machineType         String?
  machineSerialNo     String?
  machineCode         String?
  feedRate            String?
  rpm                 String?
  toolUsed            String?
  depth               String?
  temperature         String?
  completionRemark    String?
  confirmedById       String?
  confirmedBy         Employee? @relation("WOMachiningConfirm", fields: [confirmedById], references: [id])
  confirmedDate       DateTime?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model QcApproval {
  id                  String   @id @default(cuid())
  workOrderNo         String
  workOrder           WorkOrder @relation(fields: [workOrderNo], references: [workOrderNo], onDelete: Cascade)
  
  inspectorNameId     String
  inspectorName       Employee @relation("WOQCInspector", fields: [inspectorNameId], references: [id])
  qcDate              DateTime
  result              String   // Approved, Rejected
  remark              String?
  uploadUrl           String?
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model NcrReport {
  id                  String   @id @default(cuid())
  ncrNo               String   @unique
  workOrderNo         String
  workOrder           WorkOrder @relation(fields: [workOrderNo], references: [workOrderNo], onDelete: Cascade)
  
  failureMode         String?
  description         String
  issueDate           DateTime @default(now())
  reportedById        String
  reportedBy          Employee @relation("WONCRReportedBy", fields: [reportedById], references: [id])
  actionTaken         String?
  status              String   @default("Open") // Open, Closed
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
