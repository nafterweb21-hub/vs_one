generator client {
  provider   = "prisma-client-js"
  output     = "../src/generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// Currency Profile
// ==========================================
model Currency {
  id           String   @id @default(cuid())
  code         String   @unique // Immutable
  name         String   @unique // Immutable
  exchangeRate Decimal
  isDefault    Boolean  @default(false)
  status       String   @default("Active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Employee {
  id             String   @id @default(cuid())
  code           String   @unique
  name           String
  nricFin        String   @unique
  designation    String?
  email          String
  mobileNo       String?
  gender         String?  // Male / Female
  contactNo      String?
  employmentType String?  // Citizen / PR / Employment Pass / S Pass / Work Permit
  status         String   @default("ACTIVE") // ACTIVE / INACTIVE
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model TaxProfile {
  id        String   @id @default(cuid())
  taxType   String   @unique
  taxRate   Float
  status    String   @default("Active") // "Active" or "Inactive"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CustomerProfile {
  id             String                  @id @default(cuid())
  customerCode   String                  @unique
  customerName   String                  @unique
  remarks        String?
  status         String                  @default("Active") // "Active" or "Inactive"
  contactPersons CustomerContactPerson[]
  addresses      CustomerAddress[]
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
}

model CustomerContactPerson {
  id                String          @id @default(cuid())
  customerId        String
  customer          CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  contactPersonName String
  telNo             String?
  mobileNo          String?
  faxNo             String?
  email             String?
  designation       String?
  status            String          @default("Active") // "Active" or "Inactive"
  isDefault         Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

model CustomerAddress {
  id         String          @id @default(cuid())
  customerId String
  customer   CustomerProfile @relation(fields: [customerId], references: [id], onDelete: Cascade)
  address    String
  status     String          @default("Active") // "Active" or "Inactive"
  isDefault  Boolean         @default(false)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
}

// ==========================================
// UOM Profile
// ==========================================
model UomProfile {
  id        String   @id @default(cuid())
  uomName   String   @unique // Immutable after save
  remarks   String?
  status    String   @default("Active") // "Active" or "Inactive"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// Elcometer Profile
// ==========================================
model ElcometerProfile {
  id        String   @id @default(cuid())
  serialNo  String   @unique // Immutable after save
  remark    String?
  status    String   @default("Active") // "Active" or "Inactive"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// Machine Profile
// ==========================================
model MachineProfile {
  id              String   @id @default(cuid())
  machineCode     String   @unique // Immutable after save
  machineNo       String
  brand           String
  model           String
  current         String?
  serialNo        String?  // S/No
  machineType     String?  // CNC / Convention
  operationType   String?  // Milling / Turning
  remark          String?
  uploadUrl       String?  // File Upload path
  machineCategory String   // Welding Machine / Machine
  status          String   @default("Active") // "Active" or "Inactive"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}


