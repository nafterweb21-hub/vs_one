generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String           @id @default(cuid())
  name          String?
  email         String           @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  approvals     ApprovalPerson[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ApprovalLevelProfile {
  id           String           @id @default(cuid())
  module       String           // e.g., "Purchase Order - Material", "Purchase Order - Subcon"
  actionButton String?          // e.g., "First Level", "Second Level"
  minRange     Decimal?         @db.Decimal(12, 2)
  maxRange     Decimal?         @db.Decimal(12, 2)
  status       String           @default("Active") // "Active" or "Inactive"
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  approvers    ApprovalPerson[]
}

model ApprovalPerson {
  id                     String               @id @default(cuid())
  approvalLevelProfileId String
  userId                 String
  status                 String               @default("Active") // "Active" or "Inactive"
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  approvalLevelProfile   ApprovalLevelProfile @relation(fields: [approvalLevelProfileId], references: [id], onDelete: Cascade)
  user                   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([approvalLevelProfileId, userId])
}

model MaterialCategory {
  id        String   @id @default(cuid())
  category  String   @unique
  remark    String?
  status    String   @default("Active") // "Active", "Inactive", or "Void"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MaterialType {
  id        String   @id @default(cuid())
  type      String   @unique
  remark    String?
  status    String   @default("Active") // "Active", "Inactive", or "Void"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model MainProcess {
  id              String           @id @default(cuid())
  process         String           @unique
  remark          String?
  status          String           @default("Active") // "Active", "Inactive", or "Void"
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  processProfiles ProcessProfile[]
}

model ProcessProfile {
  id              String      @id @default(cuid())
  mainProcessId   String
  mainProcess     MainProcess @relation(fields: [mainProcessId], references: [id])
  routingProcess  String      @unique
  welding         Boolean     @default(false)
  sprayPainting   Boolean     @default(false)
  machining       Boolean     @default(false)
  costPerMinute   Decimal     @db.Decimal(12, 2)
  remark          String?
  status          String      @default("Active") // "Active", "Inactive", or "Void"
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}
