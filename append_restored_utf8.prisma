
// ==========================================
// Joint Profile
// ==========================================
model JointProfile {
  id        String   @id @default(cuid())
  joint     String   @unique
  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// Work Order Module
// ==========================================
model WorkOrder {
  workOrderNo         String   @id // Format: 8XXXXX-A-B
  date                DateTime
  
  customerId          String
  customer            CustomerProfile @relation(fields: [customerId], references: [id])
  
  internalQuotationNo String?
  customerPoRef       String?
  projectCode         String?
  deliveryDate        DateTime?
  jobDescription      String?
  quantity            Decimal?
  uom                 String?
  amount              Decimal?
  remark              String?
  
  qcAcceptance        String? // N/A, Rejected, Approved
  qcById              String?
  qcBy                Employee? @relation("WorkOrderQc", fields: [qcById], references: [id])
  qcDate              DateTime?
  
  labelQty            Decimal?
  labelUomId          String?
  labelUom            UomProfile? @relation(fields: [labelUomId], references: [id])
  
  status              String   @default("Draft") // Draft, Void, Proceed, WIP, On Hold, Pending for QC, Completed, Cancelled
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  inProcesses         WorkOrderInProcess[]
}

model WorkOrderInProcess {
  id                   String   @id @default(cuid())
  workOrderNo          String
  workOrder            WorkOrder @relation(fields: [workOrderNo], references: [workOrderNo], onDelete: Cascade)
  
  sn                   Int?
  description          String
  
  conditionalSnId      String?
  conditionalSn        WorkOrderInProcess?  @relation("ConditionalSn", fields: [conditionalSnId], references: [id])
  dependentProcesses   WorkOrderInProcess[] @relation("ConditionalSn")
  
  allFlag              Boolean  @default(false)
  targetCompletionDate DateTime
  remark               String?
  status               String   @default("New") // New, WIP, Completed
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  
  routingProcesses     RoutingProcess[]

  @@unique([workOrderNo, description])
}

model RoutingProcess {
  id                   String   @id @default(cuid())
  inProcessId          String
  inProcess            WorkOrderInProcess @relation(fields: [inProcessId], references: [id], onDelete: Cascade)
  
  sn                   String
  
  mainProcessId        String?
  mainProcess          MainProcess? @relation(fields: [mainProcessId], references: [id])
  
  routingProcessId     String?
  routingProcess       ProcessProfile? @relation(fields: [routingProcessId], references: [id])
  
  targetCompletionDate DateTime
  fullyReceived        Boolean  @default(false)
  remark               String?
  status               String   @default("New") // New, WIP, Completed
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  productionTimesheets ProductionTimesheet[]

  @@unique([inProcessId, sn])
}

model ProductionTimesheet {
  id                 String   @id @default(cuid())
  routingProcessId   String
  routingProcess     RoutingProcess @relation(fields: [routingProcessId], references: [id], onDelete: Cascade)
  
  employeeId         String
  employee           Employee @relation("TimesheetEmployee", fields: [employeeId], references: [id])
  
  timeIn             DateTime?
  timeOut            DateTime?
  totalMinutes       Decimal?
  completed          Boolean  @default(false)
  completedQty       Decimal?
  machineCodes       String?
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  weldingParameter   ProcessParameterWelding?
  sprayParameter     ProcessParameterSprayPainting?
  machiningParameter ProcessParameterMachining?
}

model ProcessParameterWelding {
  id                 String   @id @default(cuid())
  timesheetId        String   @unique
  timesheet          ProductionTimesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  
  weldingMachineId   String?
  weldingMachine     MachineProfile? @relation(fields: [weldingMachineId], references: [id])
  
  typeOfJointId      String?
  typeOfJoint        JointProfile? @relation(fields: [typeOfJointId], references: [id])
  
  electrodeType      String?
  weldingPosition    String?  
  weldingJoint       Decimal?
  weldingSizeMm      Decimal?
  voltageVolts       Decimal?
  currentAmp         Decimal?
  coolingTimeMins    Decimal?
  preHeatingC        Decimal?
  postHeatingC       Decimal?
  heatTreatmentHrc   Decimal?
  remark             String?
  status             String?
  
  confirmedById      String?
  confirmedBy        Employee? @relation("WeldingConfirmedBy", fields: [confirmedById], references: [id])
  confirmedDate      DateTime?
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  materialTypes      MaterialType[]       
  weldingTypes       WeldingTypeProfile[] 
}

model ProcessParameterSprayPainting {
  id                        String   @id @default(cuid())
  timesheetId               String   @unique
  timesheet                 ProductionTimesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  
  paintTankPressurePsi      Decimal
  sprayNozzleSize           Decimal
  typeOfPaint               String
  remark                    String?
  
  surfaceStartDatetime      DateTime?
  surfaceEndDatetime        DateTime?
  surfaceGeneralWeather     String?
  surfaceEnvTemperature     String?
  surfaceRelativeHumidity   String?
  surfaceAbrasiveType       String?
  surfaceSandpaperGrit      String?
  
  primerStartDatetime       DateTime?
  primerEndDatetime         DateTime?
  primerGeneralWeather      String?
  primerEnvTemperature      String?
  primerRelativeHumidity    String?
  primerPaintBatchNo        String?
  primerExpiryDate          DateTime?
  primerDftMeasurement      String?
  
  topcoatStartDatetime      DateTime?
  topcoatEndDatetime        DateTime?
  topcoatGeneralWeather     String?
  topcoatEnvTemperature     String?
  topcoatRelativeHumidity   String?
  topcoatAbrasiveType       String?
  topcoatSandpaperGrit      String?
  
  topcoatStartDatetime2     DateTime?
  topcoatEndDatetime2       DateTime?
  topcoatGeneralWeather2    String?
  topcoatEnvTemperature2    String?
  topcoatRelativeHumidity2  String?
  topcoatPaintBatchNo       String?
  topcoatExpiryDate         DateTime?
  topcoatDftMeasurement     String?
  topcoatAdhesiveTestResult String?
  
  additionalRemark          String?
  status                    String?
  
  elcometerName             String?
  elcometerSerialNoId       String?
  elcometer                 ElcometerProfile? @relation(fields: [elcometerSerialNoId], references: [id])
  
  confirmedById             String?
  confirmedBy               Employee? @relation("SprayConfirmedBy", fields: [confirmedById], references: [id])
  confirmedDate             DateTime?
  
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model ProcessParameterMachining {
  id                 String   @id @default(cuid())
  timesheetId        String   @unique
  timesheet          ProductionTimesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  
  machineSerialNoId  String
  machine            MachineProfile @relation(fields: [machineSerialNoId], references: [id])
  
  cncProgramNo       String?
  testRun            String?
  specialTooling     String?
  partRuntimeHr      Decimal?
  partRuntimeMins    Decimal?
  remark             String?
  status             String?
  
  confirmedById      String?
  confirmedBy        Employee? @relation("MachiningConfirmedBy", fields: [confirmedById], references: [id])
  confirmedDate      DateTime?
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  toolLists          MachiningToolList[]
}

model MachiningToolList {
  id                 String   @id @default(cuid())
  machiningParamId   String
  machiningParam     ProcessParameterMachining @relation(fields: [machiningParamId], references: [id], onDelete: Cascade)
  
  toolValue          Decimal
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
